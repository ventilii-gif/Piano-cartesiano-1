    <circle cx={Cpx} cy={Cpy} r={rPx} fill="rgba(8,145,178,0.10)" stroke="#0891b2" strokeWidth="2.2"/>
    {showC&&<Pt x={Cpx} y={Cpy} label="C(2,−1)" dx={5} dy={-6} fill="#dc2626" r={4}/>}
    {showR&&<><line x1={Cpx} y1={Cpy} x2={Cpx+rPx} y2={Cpy} stroke="#f97316" strokeWidth="2.2"/>
      <Lbl x={Cpx+4} y={Cpy-5} fill="#ea580c" fw="700" fs={11}>r=2</Lbl></>}
    {showEq&&<Lbl x={8} y={22} fill="#0891b2" fw="700" fs={12}>(x−2)²+(y+1)²=4</Lbl>}
    {showRes&&<Lbl x={8} y={36} fill="#10b981" fw="700" fs={11}>centro C, raggio 2 ✓</Lbl>}
  </svg>;
};

/* 19 · Completamento del quadrato: x²+y²−4x+6y−3=0 → C(2,−3), r=4 */
