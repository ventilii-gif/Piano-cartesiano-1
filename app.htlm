/* 20 · Posizione retta y=x+1 e cerchio x²+y²=8 → secante */
const Fig20=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=120,oy=95,u=20;
  const X=x=>ox+x*u, Y=y=>oy-y*u;
  const r=Math.sqrt(8),rPx=r*u;
  const showCircle=t>=0,showLine=t>=1,showPts=t>=2,showRes=t===3||t===99;
  // intersections of y=x+1 and x²+y²=8: 2x²+2x-7=0 → x=(-1±√15)/2
  const sq=Math.sqrt(15)/2;
  const x1=(-1+Math.sqrt(15))/2,y1=x1+1;
  const x2=(-1-Math.sqrt(15))/2,y2=x2+1;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-4} xMax={4} yMin={-3.5} yMax={3.5} ux={u} uy={u} grid/>
    {showCircle&&<circle cx={ox} cy={oy} r={rPx} fill="rgba(8,145,178,0.08)" stroke="#0891b2" strokeWidth="2"/>}
    {showLine&&<line x1={X(-3)} y1={Y(-2)} x2={X(2.5)} y2={Y(3.5)} stroke="#dc2626" strokeWidth="2" strokeLinecap="round"/>}
    {showPts&&<><Pt x={X(x1)} y={Y(y1)} fill="#10b981" r={4}/><Pt x={X(x2)} y={Y(y2)} fill="#10b981" r={4}/></>}
    {showRes&&<Lbl x={5} y={18} fill="#10b981" fw="700" fs={11}>Retta secante (Δ&gt;0) ✓</Lbl>}
    <Lbl x={X(1.6)} y={Y(2.8)} fill="#dc2626" fw="700" fs={10}>y=x+1</Lbl>
  </svg>;
};

/* 21 · Ellisse x²/16+y²/9=1 — a=4, b=3, fuochi F(±√7,0) */
const Fig21=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=120,oy=95,ux=22,uy=22;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const a=4,b=3,c=Math.sqrt(7);
  const showEl=t>=0,showAxes2=t>=1,showFoci=t>=2,showRes=t===3||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-5} xMax={5} yMin={-4} yMax={4} ux={ux} uy={uy} grid/>
    {showEl&&<ellipse cx={ox} cy={oy} rx={a*ux} ry={b*uy} fill="rgba(139,92,246,0.10)" stroke="#7c3aed" strokeWidth="2.2"/>}
    {showAxes2&&<>
      <line x1={X(-a)} y1={oy} x2={X(a)} y2={oy} stroke="#f97316" strokeWidth="2" strokeDasharray="5,3"/>
      <line x1={ox} y1={Y(-b)} x2={ox} y2={Y(b)} stroke="#10b981" strokeWidth="2" strokeDasharray="5,3"/>
      <Lbl x={X(a)+4} y={oy+4} fill="#ea580c" fw="700" fs={11}>a=4</Lbl>
      <Lbl x={ox+4} y={Y(b)-3} fill="#059669" fw="700" fs={11}>b=3</Lbl>
    </>}
    {showFoci&&<>
      <Pt x={X(c)} y={oy} label={`F₁`} dx={4} dy={-7} fill="#dc2626" r={4}/>
      <Pt x={X(-c)} y={oy} label={`F₂`} dx={-18} dy={-7} fill="#dc2626" r={4}/>
      <Lbl x={5} y={20} fill="#dc2626" fw="700" fs={11}>c=√7≈2.65</Lbl>
    </>}
    {showRes&&<Lbl x={5} y={32} fill="#10b981" fw="700" fs={11}>F(±√7,0) ✓</Lbl>}
  </svg>;
};

/* 22 · Ellisse traslata (x−1)²/9+(y+2)²/4=1, centro C(1,−2) */
const Fig22=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=80,oy=140,ux=20,uy=20;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const h=1,k=-2,a=3,b=2;
  const showEl=t>=0,showC=t>=1,showRes=t===2||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-1.5} xMax={6} yMin={-5} yMax={1.5} ux={ux} uy={uy} grid/>
    {showEl&&<ellipse cx={X(h)} cy={Y(k)} rx={a*ux} ry={b*uy} fill="rgba(139,92,246,0.10)" stroke="#7c3aed" strokeWidth="2.2"/>}
    {showC&&<Pt x={X(h)} y={Y(k)} label="C(1,−2)" dx={5} dy={-6} fill="#dc2626" r={4}/>}
    {showRes&&<><Lbl x={5} y={20} fill="#7c3aed" fw="700" fs={11}>a=3, b=2</Lbl>
      <Lbl x={5} y={32} fill="#10b981" fw="700" fs={11}>Centro C(1,−2) ✓</Lbl></>}
  </svg>;
};

/* 23 · Iperbole x²/4−y²/9=1, a=2, b=3, asintoti y=±(3/2)x */
const Fig23=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=120,oy=95,ux=22,uy=16;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const a=2,b=3,steps=40;
  const makeHyp=(sign)=>{
    const pts=[];
    for(let i=0;i<=steps;i++){const u2=i/steps*2.5;const x=a*Math.cosh(u2);const y=b*Math.sinh(u2)*sign;pts.push(`${X(x).toFixed(1)},${Y(y).toFixed(1)}`);}
    return pts.join(" ");
  };
  const makeHypL=(sign)=>{
    const pts=[];
    for(let i=0;i<=steps;i++){const u2=i/steps*2.5;const x=-a*Math.cosh(u2);const y=b*Math.sinh(u2)*sign;pts.push(`${X(x).toFixed(1)},${Y(y).toFixed(1)}`);}
    return pts.join(" ");
  };
  const showH=t>=0,showAs=t>=1,showRes=t===3||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-5} xMax={5} yMin={-5.5} yMax={5.5} ux={ux} uy={uy} grid/>
    {showAs&&<>
      <line x1={X(-5)} y1={Y(-5*b/a)} x2={X(5)} y2={Y(5*b/a)} stroke="#f97316" strokeWidth="1.5" strokeDasharray="5,3"/>
      <line x1={X(-5)} y1={Y(5*b/a)} x2={X(5)} y2={Y(-5*b/a)} stroke="#f97316" strokeWidth="1.5" strokeDasharray="5,3"/>
      <Lbl x={X(2.8)} y={Y(4.5)} fill="#ea580c" fw="700" fs={10}>y=3/2·x</Lbl>
    </>}
    {showH&&<>
      <polyline points={makeHyp(1)} fill="none" stroke="#0891b2" strokeWidth="2.2" strokeLinecap="round"/>
      <polyline points={makeHyp(-1)} fill="none" stroke="#0891b2" strokeWidth="2.2" strokeLinecap="round"/>
      <polyline points={makeHypL(1)} fill="none" stroke="#0891b2" strokeWidth="2.2" strokeLinecap="round"/>
      <polyline points={makeHypL(-1)} fill="none" stroke="#0891b2" strokeWidth="2.2" strokeLinecap="round"/>
    </>}
    {showRes&&<Lbl x={5} y={20} fill="#10b981" fw="700" fs={11}>asintoti y=±3/2·x ✓</Lbl>}
  </svg>;
};

/* 24 · Iperbole traslata (x+1)²/9−(y−2)²/4=1, centro C(−1,2) */
const Fig24=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=120,oy=135,ux=20,uy=18;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const h=-1,k=2,a=3,b=2,nSteps=40;
  const makeB=(sx,sy)=>{
    const pts=[];
    for(let i=0;i<=nSteps;i++){const u=i/nSteps*2.2;const x=h+sx*a*Math.cosh(u);const y=k+sy*b*Math.sinh(u);pts.push(`${X(x).toFixed(1)},${Y(y).toFixed(1)}`);}
    return pts.join(" ");
  };
  const showH=t>=0,showC=t>=1,showAs=t>=2,showRes=t===3||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-5.5} xMax={4} yMin={-4} yMax={6} ux={ux} uy={uy} grid/>
    {showAs&&<>
      <line x1={X(-6)} y1={Y(k-b/a*((-6)-h))} x2={X(4)} y2={Y(k+b/a*(4-h))} stroke="#f97316" strokeWidth="1.4" strokeDasharray="5,3"/>
      <line x1={X(-6)} y1={Y(k+b/a*((-6)-h))} x2={X(4)} y2={Y(k-b/a*(4-h))} stroke="#f97316" strokeWidth="1.4" strokeDasharray="5,3"/>
    </>}
    {showH&&<>
      <polyline points={makeB(1,1)} fill="none" stroke="#0891b2" strokeWidth="2" strokeLinecap="round"/>
      <polyline points={makeB(1,-1)} fill="none" stroke="#0891b2" strokeWidth="2" strokeLinecap="round"/>
      <polyline points={makeB(-1,1)} fill="none" stroke="#0891b2" strokeWidth="2" strokeLinecap="round"/>
      <polyline points={makeB(-1,-1)} fill="none" stroke="#0891b2" strokeWidth="2" strokeLinecap="round"/>
    </>}
    {showC&&<Pt x={X(h)} y={Y(k)} label="C(−1,2)" dx={5} dy={-6} fill="#dc2626" r={4}/>}
    {showRes&&<Lbl x={5} y={18} fill="#10b981" fw="700" fs={11}>Centro C(−1,2) ✓</Lbl>}
  </svg>;
};

/* 25 · Funzione omografica y=(2x+1)/(x−3): asintoti x=3, y=2 */
const Fig25=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=100,oy=95,ux=20,uy=18;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const f=x=>(2*x+1)/(x-3);
  const makeBranch=(xStart,xEnd,skip=false)=>{
    const pts=[];
    for(let i=0;i<=60;i++){
      const x=xStart+(xEnd-xStart)*i/60;
      if(Math.abs(x-3)<0.15)continue;
      const y=f(x);
      if(y<-8||y>8)continue;
      pts.push(`${X(x).toFixed(1)},${Y(y).toFixed(1)}`);
    }
    return pts.join(" ");
  };
  const showF=t>=0,showAv=t>=1,showAo=t>=2,showRes=t===4||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-2} xMax={7} yMin={-5} yMax={8} ux={ux} uy={uy} grid/>
    {showAv&&<line x1={X(3)} y1={Y(-5)} x2={X(3)} y2={Y(8)} stroke="#dc2626" strokeWidth="1.5" strokeDasharray="5,3"/>}
    {showAo&&<line x1={X(-2)} y1={Y(2)} x2={X(7)} y2={Y(2)} stroke="#f97316" strokeWidth="1.5" strokeDasharray="5,3"/>}
    {showF&&<>
      <polyline points={makeBranch(-2,2.85)} fill="none" stroke="#0891b2" strokeWidth="2.2" strokeLinecap="round"/>
      <polyline points={makeBranch(3.15,7)} fill="none" stroke="#0891b2" strokeWidth="2.2" strokeLinecap="round"/>
    </>}
    {showAv&&<Lbl x={X(3)+4} y={Y(7)} fill="#dc2626" fw="700" fs={11}>x=3</Lbl>}
    {showAo&&<Lbl x={X(6)} y={Y(2)-7} fill="#ea580c" fw="700" fs={11}>y=2</Lbl>}
    {showRes&&<Lbl x={5} y={20} fill="#10b981" fw="700" fs={11}>asintoti x=3, y=2 ✓</Lbl>}
  </svg>;
};

const FIGS={1:Fig1,2:Fig2,3:Fig3,4:Fig4,5:Fig5,6:Fig6,7:Fig7,8:Fig8,9:Fig9,10:Fig10,11:Fig11,12:Fig12,13:Fig13,14:Fig14,15:Fig15,16:Fig16,17:Fig17,18:Fig18,19:Fig19,20:Fig20,21:Fig21,22:Fig22,23:Fig23,24:Fig24,25:Fig25};

const CARDS=[

  {id:1,title:"Distanza tra due punti",cat:"Piano Cartesiano",diff:1,
    stmt:"La distanza tra A(x₁,y₁) e B(x₂,y₂) si calcola con d = √((x₂−x₁)² + (y₂−y₁)²), formula derivata dal teorema di Pitagora.",
    hyp:"A(1, 1) e B(4, 3)",tesi:"d(A,B) = √13 ≈ 3.61 unità",
    idea:"💡 Costruisci il triangolo rettangolo con i cateti paralleli agli assi: la distanza è l'ipotenusa.",
    steps:[
      {ti:"Differenza delle ascisse",tx:"Δx = x₂ − x₁ = 4 − 1 = 3",hi:"Δx misura lo spostamento orizzontale tra A e B."},
      {ti:"Differenza delle ordinate",tx:"Δy = y₂ − y₁ = 3 − 1 = 2",hi:"Δy misura lo spostamento verticale."},
      {ti:"Costruisci il triangolo rettangolo",tx:"I segmenti Δx e Δy sono i cateti; il segmento AB è l'ipotenusa.",hi:"L'angolo retto si forma perché un cateto è orizzontale e l'altro verticale."},
      {ti:"Applica il teorema di Pitagora",tx:"d² = Δx² + Δy² = 9 + 4 = 13   →   d = √13",hi:"In ogni triangolo rettangolo, ipotenusa² = somma dei quadrati dei cateti."},
      {ti:"Risultato",tx:"d(A,B) = √13 ≈ 3.61 unità ✓",hi:"Conserva sempre il valore esatto in radice quando possibile; il decimale è solo un'approssimazione."}
    ]},
  {id:2,title:"Punto medio di un segmento",cat:"Piano Cartesiano",diff:1,
    stmt:"Il punto medio M di un segmento ha coordinate uguali alla media aritmetica delle coordinate degli estremi.",
    hyp:"A(−2, 2) e B(4, −2)",tesi:"M(1, 0)",
    idea:"💡 La media è il valore equidistante: la applichi separatamente alle ascisse e alle ordinate.",
    steps:[
      {ti:"Coordinata x del punto medio",tx:"x_M = (x_A + x_B)/2 = (−2 + 4)/2 = 1",hi:"Sommi le ascisse e dividi per 2."},
      {ti:"Coordinata y del punto medio",tx:"y_M = (y_A + y_B)/2 = (2 + (−2))/2 = 0",hi:"Stesso procedimento per le ordinate."},
      {ti:"Concludi",tx:"M = (1, 0) ✓",hi:"Verifica veloce: AM e MB devono essere uguali, e infatti lo sono."}
    ]},
  {id:3,title:"Perimetro di un triangolo",cat:"Piano Cartesiano",diff:2,
    stmt:"Calcola il perimetro del triangolo di vertici A(1,1), B(5,1), C(5,4).",
    hyp:"A(1,1), B(5,1), C(5,4)",tesi:"p = 12 unità",
    idea:"💡 Riconoscere i lati paralleli agli assi rende il calcolo immediato: bastano differenze in valore assoluto.",
    steps:[
      {ti:"Lato AB (orizzontale)",tx:"A e B hanno la stessa ordinata (y=1) → AB è orizzontale.  AB = |x_B − x_A| = |5 − 1| = 4",hi:"Quando due punti condividono la y, il segmento è orizzontale."},
      {ti:"Lato BC (verticale)",tx:"B e C hanno la stessa ascissa (x=5) → BC è verticale.  BC = |y_C − y_B| = |4 − 1| = 3",hi:"Quando due punti condividono la x, il segmento è verticale."},
      {ti:"Lato CA (diagonale)",tx:"CA = √((x_C − x_A)² + (y_C − y_A)²) = √(16 + 9) = √25 = 5",hi:"Per i lati obliqui usa sempre la formula generale della distanza."},
      {ti:"Somma dei tre lati",tx:"p = AB + BC + CA = 4 + 3 + 5 = 12 unità ✓",hi:"Il triangolo è una terna pitagorica 3-4-5 → è rettangolo in B."}
    ]},
  {id:4,title:"Riconoscere un parallelogramma",cat:"Piano Cartesiano",diff:2,
    stmt:"Verifica che il quadrilatero ABCD con A(0,0), B(4,0), C(5,3), D(1,3) è un parallelogramma.",
    hyp:"A(0,0), B(4,0), C(5,3), D(1,3)",tesi:"M(AC) = M(BD) → ABCD parallelogramma",
    idea:"💡 Una proprietà caratterizzante del parallelogramma: le diagonali si bisecano. Basta verificare che i punti medi delle diagonali coincidano.",
    steps:[
      {ti:"Individua le diagonali",tx:"Le diagonali del quadrilatero ABCD sono AC e BD.",hi:"In un quadrilatero ABCD, le diagonali uniscono vertici opposti: A↔C e B↔D."},
      {ti:"Punto medio di AC",tx:"M(AC) = ((0+5)/2, (0+3)/2) = (2.5, 1.5)",hi:"Applica la formula del punto medio dimostrata in precedenza."},
      {ti:"Punto medio di BD",tx:"M(BD) = ((4+1)/2, (0+3)/2) = (2.5, 1.5)",hi:"Stesso procedimento per l'altra diagonale."},
      {ti:"Concludi",tx:"I punti medi coincidono → le diagonali si bisecano → ABCD è un parallelogramma ✓",hi:"È una caratterizzazione: vale anche il viceversa."}
    ]},
  {id:5,title:"Equazione esplicita y = mx + q",cat:"La Retta",diff:1,
    stmt:"Una retta non verticale è descritta dall'equazione y = mx + q, dove m è la pendenza e q l'intercetta sull'asse y.",
    hyp:"Retta non verticale nel piano cartesiano",tesi:"y = mx + q  (m, q ∈ ℝ)",
    idea:"💡 q dice 'dove la retta taglia l'asse y'; m dice 'quanto sale ogni passo orizzontale'.",
    steps:[
      {ti:"Intercetta q",tx:"Per x = 0 si ottiene y = q: la retta interseca l'asse y nel punto (0, q).",hi:"Sostituisci x=0 nell'equazione e ricavi y."},
      {ti:"Pendenza m",tx:"m è il coefficiente angolare: indica di quanto cambia y quando x aumenta di 1.",hi:"m = Δy / Δx tra due punti qualsiasi della retta."},
      {ti:"Esempio: y = 2x + 1",tx:"Intercetta in (0, 1); per ogni passo orizzontale di +1, y sale di +2.",hi:"Visualizza il 'triangolo della pendenza' con cateti +1 e +2."},
      {ti:"Verifica con un punto",tx:"Il punto (1, 3) appartiene alla retta? 3 = 2·1 + 1 = 3 ✓",hi:"Per verificare l'appartenenza, sostituisci nelle coordinate: l'equazione deve essere soddisfatta."}
    ]},
  {id:6,title:"Calcolo della pendenza",cat:"La Retta",diff:1,
    stmt:"La pendenza di una retta passante per due punti è m = (y₂ − y₁)/(x₂ − x₁) = tan(α), dove α è l'angolo che la retta forma con l'asse x.",
    hyp:"P₁(0, 1) e P₂(2, 5)",tesi:"m = 2",
    idea:"💡 La pendenza è la 'salita per ogni passo orizzontale'. Geometricamente, è la tangente dell'angolo che la retta forma con l'asse x.",
    steps:[
      {ti:"Identifica i due punti",tx:"P₁(0, 1) → x₁=0, y₁=1.   P₂(2, 5) → x₂=2, y₂=5.",hi:"Etichetta sempre i punti per evitare errori di segno."},
      {ti:"Calcola Δy",tx:"Δy = y₂ − y₁ = 5 − 1 = 4",hi:"È fondamentale rispettare l'ordine: stesso 'pedice' al numeratore e al denominatore."},
      {ti:"Calcola Δx",tx:"Δx = x₂ − x₁ = 2 − 0 = 2",hi:"Δx ≠ 0, altrimenti la retta sarebbe verticale e m non esisterebbe."},
      {ti:"Pendenza",tx:"m = Δy / Δx = 4 / 2 = 2",hi:"Se inverti l'ordine di P₁ e P₂, sia Δx sia Δy cambiano segno: il rapporto resta lo stesso."},
      {ti:"Interpretazione",tx:"m = 2 > 0 e > 1: retta crescente, ripida (angolo > 45°).",hi:"Tabella mentale: m>0 cresce, m<0 decresce, m=0 orizzontale, |m|>1 ripida."}
    ]},
  {id:7,title:"Retta passante per due punti",cat:"La Retta",diff:2,
    stmt:"Trova l'equazione della retta passante per A(1, 3) e B(4, −3).",
    hyp:"A(1, 3), B(4, −3)",tesi:"y = −2x + 5",
    idea:"💡 Procedimento standard: prima la pendenza, poi sostituisci in y − y₀ = m(x − x₀) usando uno dei due punti.",
    steps:[
      {ti:"Calcola la pendenza",tx:"m = (y_B − y_A)/(x_B − x_A) = (−3 − 3)/(4 − 1) = −6/3 = −2",hi:"Attento ai segni: −3 − 3 = −6, non 0!"},
      {ti:"Forma punto-pendenza",tx:"Usando A(1,3): y − 3 = −2(x − 1)",hi:"Funzionerebbe ugualmente con B; il risultato finale sarà identico."},
      {ti:"Sviluppa e semplifica",tx:"y − 3 = −2x + 2  →  y = −2x + 5",hi:"Distribuisci il −2 e isola y."},
      {ti:"Verifica con l'altro punto",tx:"B(4,−3): −2·4 + 5 = −8 + 5 = −3 ✓",hi:"Sostituisci sempre l'altro punto: se l'equazione non torna, hai sbagliato qualcosa."}
    ]},
  {id:8,title:"Rette parallele e perpendicolari",cat:"La Retta",diff:2,
    stmt:"Due rette sono parallele se hanno la stessa pendenza; perpendicolari se il prodotto delle pendenze è −1.",
    hyp:"Rette r: y = m₁x + q₁  e  s: y = m₂x + q₂",tesi:"r ∥ s ⟺ m₁ = m₂.   r ⊥ s ⟺ m₁·m₂ = −1",
    idea:"💡 Stessa direzione → stessa pendenza. Direzione perpendicolare → pendenze 'reciproche e di segno opposto'.",
    steps:[
      {ti:"Rette parallele",tx:"y = 2x + 1  e  y = 2x − 3 hanno entrambe m = 2 → sono parallele (e distinte, perché q diversi).",hi:"Se anche le q coincidessero, sarebbero la stessa retta (coincidenti)."},
      {ti:"Rette perpendicolari",tx:"y = 2x  e  y = −x/2 hanno m₁ = 2, m₂ = −1/2.  Prodotto: 2·(−1/2) = −1 → perpendicolari.",hi:"Per ottenere la perpendicolare a una retta data: scambia il segno e fai il reciproco di m."},
      {ti:"Caso particolare delle rette verticali",tx:"Una retta verticale x = k non ha pendenza definita (m → ∞). È perpendicolare a ogni retta orizzontale y = h.",hi:"Le rette verticali e orizzontali si trattano sempre a parte."},
      {ti:"In sintesi",tx:"Parallele: stessa direzione, stesso m.  Perpendicolari: si tagliano a 90°, m₁·m₂ = −1.",hi:"Memorizza la regola del prodotto: è la più usata negli esercizi."}
    ]},
  {id:9,title:"Distanza punto-retta",cat:"La Retta",diff:2,
    stmt:"Calcola la distanza del punto P(3, 3) dalla retta r: 2x + y − 2 = 0.",
    hyp:"P(3, 3), retta r: 2x + y − 2 = 0",tesi:"d(P, r) = 7/√5 = 7√5/5 ≈ 3.13",
    idea:"💡 Porta sempre prima la retta in forma implicita ax + by + c = 0; poi applica la formula d = |ax₀+by₀+c| / √(a²+b²).",
    steps:[
      {ti:"Forma implicita: identifica a, b, c",tx:"r: 2x + y − 2 = 0  →  a = 2, b = 1, c = −2",hi:"Se la retta è data in forma esplicita y = mx + q, riscrivila come mx − y + q = 0."},
      {ti:"Calcola il numeratore",tx:"|a·x_P + b·y_P + c| = |2·3 + 1·3 + (−2)| = |6 + 3 − 2| = |7| = 7",hi:"Il valore assoluto garantisce che la distanza sia non-negativa."},
      {ti:"Calcola il denominatore",tx:"√(a² + b²) = √(4 + 1) = √5",hi:"Il denominatore dipende solo dalla retta, mai dal punto."},
      {ti:"Risultato",tx:"d(P, r) = 7/√5 = 7√5/5 ≈ 3.13 ✓",hi:"Razionalizza il denominatore moltiplicando sopra e sotto per √5."}
    ]},
  {id:10,title:"Punto di minima distanza da una retta",cat:"La Retta",diff:3,
    stmt:"Trova il punto della retta y = 2x + 1 che ha minima distanza dal punto P(4, 0).",
    hyp:"Retta r: y = 2x + 1, punto P(4, 0)",tesi:"Q(2/5, 9/5)",
    idea:"💡 Il punto più vicino è il piede della perpendicolare condotta da P alla retta r. Costruisci la perpendicolare per P e trovala.",
    steps:[
      {ti:"Pendenza della perpendicolare",tx:"r ha pendenza m = 2 → la perpendicolare ha m_⊥ = −1/2 (prodotto −1).",hi:"Riusa la regola del prodotto −1 dimostrata in precedenza."},
      {ti:"Equazione della perpendicolare per P",tx:"y − 0 = −1/2 (x − 4)  →  y = −x/2 + 2",hi:"Forma punto-pendenza con (4, 0) e m = −1/2."},
      {ti:"Sistema retta–perpendicolare",tx:"2x + 1 = −x/2 + 2  →  4x + 2 = −x + 4  →  5x = 2  →  x = 2/5",hi:"Per evitare frazioni, moltiplica entrambi i membri per 2 prima di risolvere."},
      {ti:"Coordinate del punto Q",tx:"y = 2·(2/5) + 1 = 4/5 + 5/5 = 9/5  →  Q(2/5, 9/5) ✓",hi:"Sostituisci la x trovata in una delle due equazioni — meglio nella più semplice."}
    ]},
  {id:11,title:"Anatomia della parabola",cat:"La Parabola",diff:1,
    stmt:"Una parabola y = ax² + bx + c (con a ≠ 0) ha vertice V, asse di simmetria, fuoco F e direttrice.",
    hyp:"y = ax² + bx + c con a ≠ 0",tesi:"V(−b/2a, −Δ/4a); F(x_V, y_V + 1/4a); direttrice y = y_V − 1/4a",
    idea:"💡 a determina la concavità e l'apertura; b e c spostano la parabola, ma le formule per V, F, direttrice restano le stesse.",
    steps:[
      {ti:"Concavità (segno di a)",tx:"a > 0 → parabola rivolta verso l'alto (V è punto di minimo).  a < 0 → verso il basso (V è massimo).",hi:"Più |a| è grande, più la parabola è 'stretta'."},
      {ti:"Coordinate del vertice",tx:"x_V = −b/(2a);   y_V = −Δ/(4a),  dove Δ = b² − 4ac.   In alternativa: y_V = f(x_V).",hi:"Calcola sempre prima x_V; poi sostituiscilo per ottenere y_V (più rapido)."},
      {ti:"Asse di simmetria",tx:"È la retta verticale x = x_V che passa per il vertice. La parabola è simmetrica rispetto a essa.",hi:"Due punti con la stessa y hanno x simmetriche rispetto a x_V."},
      {ti:"Fuoco e direttrice",tx:"F(x_V, y_V + 1/(4a));   direttrice: retta orizzontale y = y_V − 1/(4a).",hi:"Definizione di parabola: luogo dei punti equidistanti da F e dalla direttrice."}
    ]},
  {id:12,title:"Studio completo: y = 2x² − 4x − 6",cat:"La Parabola",diff:3,
    stmt:"Studia la parabola y = 2x² − 4x − 6: trova vertice, fuoco, direttrice, intersezioni con gli assi.",
    hyp:"y = 2x² − 4x − 6  (a = 2, b = −4, c = −6)",tesi:"V(1, −8); radici x = −1 e x = 3; intercetta (0, −6)",
    idea:"💡 Procedi sempre nello stesso ordine: discriminante → vertice → fuoco e direttrice → radici → intercetta sull'asse y.",
    steps:[
      {ti:"Discriminante",tx:"Δ = b² − 4ac = (−4)² − 4·2·(−6) = 16 + 48 = 64",hi:"Attento ai segni quando c è negativo: −4·2·(−6) = +48."},
      {ti:"Coordinate del vertice",tx:"x_V = −b/(2a) = 4/4 = 1.   y_V = −Δ/(4a) = −64/8 = −8.   →  V(1, −8)",hi:"In alternativa: y_V = 2·1² − 4·1 − 6 = 2 − 4 − 6 = −8."},
      {ti:"Fuoco e direttrice",tx:"1/(4a) = 1/8.   F(1, −8 + 1/8) = F(1, −63/8).   Direttrice: y = −8 − 1/8 = −65/8.",hi:"Il fuoco è sempre 'dentro' la concavità; la direttrice è dalla parte opposta rispetto al vertice."},
      {ti:"Intersezioni con l'asse x (radici)",tx:"x = (−b ± √Δ)/(2a) = (4 ± 8)/4   →   x = 3 oppure x = −1.   Punti: (−1, 0) e (3, 0).",hi:"Δ > 0 → due radici reali distinte → la parabola taglia l'asse x in due punti."},
      {ti:"Intersezione con l'asse y",tx:"Per x = 0: y = c = −6.   Punto: (0, −6).",hi:"L'intercetta sull'asse y è sempre uguale al termine noto c."}
    ]},
  {id:13,title:"Intersezione retta–parabola",cat:"La Parabola",diff:2,
    stmt:"Trova le intersezioni tra la retta y = 2x e la parabola y = x² − 2x.",
    hyp:"Retta r: y = 2x;   parabola P: y = x² − 2x",tesi:"Due intersezioni: (0, 0) e (4, 8)",
    idea:"💡 Imposta il sistema retta–parabola, sostituisci e risolvi un'equazione di 2° grado: il numero di soluzioni dipende dal segno del Δ.",
    steps:[
      {ti:"Imposta il sistema",tx:"Imponi y_retta = y_parabola:   2x = x² − 2x",hi:"Il sistema {y=2x; y=x²−2x} si riduce a una sola equazione in x."},
      {ti:"Equazione di 2° grado",tx:"x² − 2x − 2x = 0  →  x² − 4x = 0  →  x(x − 4) = 0",hi:"Quando manca il termine noto, raccogli x: è il modo più rapido."},
      {ti:"Soluzioni in x",tx:"x = 0  oppure  x = 4   (Δ > 0: due intersezioni distinte)",hi:"Δ = b² − 4ac = 16 > 0 conferma le due soluzioni reali."},
      {ti:"Calcola le ordinate",tx:"Per x = 0: y = 2·0 = 0.   Per x = 4: y = 2·4 = 8.",hi:"Sostituisci nell'equazione più semplice (la retta) per non sbagliare."},
      {ti:"Punti di intersezione",tx:"Le intersezioni sono (0, 0) e (4, 8) ✓",hi:"In generale: Δ>0 → 2 punti; Δ=0 → tangenza; Δ<0 → nessuna intersezione."}
    ]},
  {id:14,title:"Condizione di tangenza retta–parabola",cat:"La Parabola",diff:3,
    stmt:"Determina k affinché la retta y = 2x + k sia tangente alla parabola y = x² + 2.",
    hyp:"Retta r: y = 2x + k;   parabola P: y = x² + 2",tesi:"k = 1; punto di tangenza T(1, 3)",
    idea:"💡 Tangenza ⟺ il sistema retta–parabola ha una sola soluzione (doppia) ⟺ il discriminante dell'equazione risolvente è zero.",
    steps:[
      {ti:"Imposta il sistema",tx:"Uguaglia le due espressioni:   2x + k = x² + 2",hi:"Stesso schema dell'intersezione, ma con k come parametro incognito."},
      {ti:"Equazione risolvente",tx:"Riordina: x² − 2x + (2 − k) = 0",hi:"Identifica i coefficienti: A = 1, B = −2, C = 2 − k."},
      {ti:"Imponi Δ = 0",tx:"Δ = (−2)² − 4·1·(2 − k) = 4 − 8 + 4k = 4k − 4   →   4k − 4 = 0   →   k = 1",hi:"Δ = 0 è la condizione algebrica della tangenza."},
      {ti:"Trova il punto di tangenza",tx:"Con k = 1: x² − 2x + 1 = 0 → (x − 1)² = 0 → x = 1 (radice doppia).",hi:"Una soluzione doppia significa: i due punti di intersezione 'collassano' in uno solo."},
      {ti:"Coordinate del punto T",tx:"y = 2·1 + 1 = 3   →   T(1, 3) ✓",hi:"Verifica: T deve appartenere a entrambe le curve. 1² + 2 = 3 ✓"}
    ]},
  {id:15,title:"Parabola passante per tre punti",cat:"La Parabola",diff:3,
    stmt:"Trova la parabola con asse parallelo all'asse y passante per A(0, 3), B(1, 0), C(−1, 8).",
    hyp:"A(0, 3), B(1, 0), C(−1, 8)",tesi:"y = x² − 4x + 3",
    idea:"💡 Sostituisci ogni punto in y = ax² + bx + c per ottenere un sistema di 3 equazioni nelle 3 incognite a, b, c.",
    steps:[
      {ti:"Sostituisci A(0, 3)",tx:"3 = a·0² + b·0 + c   →   c = 3",hi:"I punti sull'asse y danno direttamente il valore di c (spesso il punto più 'comodo')."},
      {ti:"Sostituisci B(1, 0)",tx:"0 = a·1² + b·1 + 3   →   a + b = −3",hi:"Riduci subito il sistema usando c già noto."},
      {ti:"Sostituisci C(−1, 8)",tx:"8 = a·(−1)² + b·(−1) + 3   →   a − b = 5",hi:"Attento al segno di b·(−1) = −b."},
      {ti:"Risolvi il sistema 2×2",tx:"Sommando le due equazioni:  2a = 2  →  a = 1.  Sostituendo: b = −3 − 1 = −4.",hi:"Il metodo di addizione/sottrazione è il più rapido quando i coefficienti sono opposti."},
      {ti:"Equazione finale",tx:"y = x² − 4x + 3 ✓",hi:"Verifica: B(1,0) → 1 − 4 + 3 = 0 ✓.   C(−1,8) → 1 + 4 + 3 = 8 ✓."}
    ]},
  {id:16,title:"Tangente e normale alla parabola",cat:"La Parabola",diff:3,
    stmt:"Sapendo che y = 2x + 1 è tangente a y = x² + 2 nel punto T(1, 3), trova l'equazione della retta normale alla parabola in T.",
    hyp:"Tangente: y = 2x + 1; punto di tangenza T(1, 3)",tesi:"Normale: y = −x/2 + 7/2",
    idea:"💡 La normale è la retta perpendicolare alla tangente nel punto di tangenza: m_n · m_t = −1.",
    steps:[
      {ti:"Pendenza della tangente",tx:"La tangente è y = 2x + 1   →   m_t = 2",hi:"Si legge direttamente dal coefficiente di x in forma esplicita."},
      {ti:"Pendenza della normale",tx:"m_n · m_t = −1   →   m_n = −1/m_t = −1/2",hi:"Stessa regola delle rette perpendicolari (Carta n.8)."},
      {ti:"Equazione della normale per T(1, 3)",tx:"y − 3 = −1/2 (x − 1)",hi:"Forma punto-pendenza con T e m_n."},
      {ti:"Sviluppa",tx:"y = −x/2 + 1/2 + 3 = −x/2 + 7/2",hi:"1/2 + 3 = 1/2 + 6/2 = 7/2."},
      {ti:"Verifica del passaggio per T",tx:"T(1, 3):  y = −1/2 + 7/2 = 6/2 = 3 ✓",hi:"La verifica per T dovrebbe essere automatica per costruzione."}
    ]},

  /* ── Le Coniche ── */
  {id:17,title:"Circonferenza centrata nell'origine",cat:"Le Coniche",diff:1,
   stmt:"La circonferenza con centro O(0,0) e raggio r è il luogo dei punti del piano a distanza r dall'origine. La sua equazione è x²+y²=r².",
   hyp:"Centro O(0,0), raggio r=3",tesi:"x²+y²=9",
   idea:"💡 Ogni punto P(x,y) sulla circonferenza soddisfa d(P,O)=r. Applica la formula della distanza e quadra entrambi i membri.",
   steps:[
     {ti:"Condizione di appartenenza",tx:"P(x,y) sta sulla circonferenza sse d(P,O)=r, cioè √(x²+y²)=r.",hi:"La distanza dall'origine è sempre √(x²+y²)."},
     {ti:"Eleva al quadrato",tx:"√(x²+y²)=r → x²+y²=r²=9.",hi:"Elevare al quadrato elimina la radice (r>0 garantisce l'equivalenza)."},
     {ti:"Verifica con un punto",tx:"P(3,0): 9+0=9 ✓. P(0,-3): 0+9=9 ✓.",hi:"Scegli sempre punti sugli assi per verificare rapidamente."},
     {ti:"Equazione finale",tx:"x²+y²=9 ✓. Il cerchio ha centro O e r=3.",hi:"L'equazione è simmetrica in x e y: il cerchio è simmetrico rispetto a entrambi gli assi."},
   ]},
  {id:18,title:"Circonferenza con centro generico",cat:"Le Coniche",diff:1,
   stmt:"La circonferenza con centro C(a,b) e raggio r ha equazione (x−a)²+(y−b)²=r². È la forma canonica della circonferenza.",
   hyp:"C(2,−1), r=2",tesi:"(x−2)²+(y+1)²=4",
   idea:"💡 La distanza di P(x,y) da C(a,b) deve essere uguale a r: scrivi la formula e quadra.",
   steps:[
     {ti:"Scrivi la condizione d(P,C)=r",tx:"√((x−a)²+(y−b)²)=r → (x−a)²+(y−b)²=r².",hi:"La traslazione del centro cambia x in (x−a) e y in (y−b)."},
     {ti:"Sostituisci i dati",tx:"a=2, b=−1, r=2: (x−2)²+(y+1)²=4.",hi:"Attenzione al segno: b=−1 → (y−(−1))=(y+1)."},
     {ti:"Verifica",tx:"C(2,−1): (0)²+(0)²=0≠4 (il centro è interno, non sulla curva). P(4,−1): (2)²+(0)²=4 ✓.",hi:"Il centro non appartiene alla circonferenza: la sua distanza dal centro è 0<r."},
     {ti:"Equazione finale",tx:"(x−2)²+(y+1)²=4 ✓",hi:""},
   ]},
  {id:19,title:"Dalla forma generale alla canonica",cat:"Le Coniche",diff:2,
   stmt:"L'equazione x²+y²+Dx+Ey+F=0 si trasforma in forma canonica completando il quadrato. Si ottengono centro C(−D/2, −E/2) e r=√((D/2)²+(E/2)²−F).",
   hyp:"x²+y²−4x+6y−3=0",tesi:"Centro C(2,−3), raggio r=4",
   idea:"💡 Raggruppa i termini in x e in y, poi completa il quadrato aggiungendo e sottraendo le costanti opportune.",
   steps:[
     {ti:"Raggruppa per variabile",tx:"(x²−4x)+(y²+6y)=3",hi:"Porta la costante F a destra: F=−3 → 3 a destra."},
     {ti:"Completa il quadrato in x",tx:"x²−4x+4=(x−2)², aggiungi 4 ad entrambi i membri: (x−2)²+(y²+6y)=3+4=7.",hi:"Per x²+px, aggiungi (p/2)²=(−4/2)²=4."},
     {ti:"Completa il quadrato in y",tx:"y²+6y+9=(y+3)², aggiungi 9: (x−2)²+(y+3)²=7+9=16.",hi:"Per y²+qy, aggiungi (q/2)²=(6/2)²=9."},
     {ti:"Leggi centro e raggio",tx:"(x−2)²+(y+3)²=16 → C(2,−3), r=√16=4.",hi:"Il centro ha coordinate (a,b) dove a e b sono quelli che azzerano i quadrati."},
     {ti:"Verifica",tx:"C(2,−3): 4+9−8−18−3=−16≠0. Punto (2+4,−3)=(6,−3): 36+9−24−18−3=0 ✓",hi:"Il centro non soddisfa l'equazione; un punto sul cerchio sì."},
   ]},
  {id:20,title:"Posizione retta-circonferenza",cat:"Le Coniche",diff:2,
   stmt:"Per studiare la posizione reciproca di una retta e una circonferenza, sostituisci la retta nel sistema e calcola il discriminante Δ: Δ>0 secante, Δ=0 tangente, Δ<0 esterna.",
   hyp:"Retta y=x+1, circonferenza x²+y²=8",tesi:"Retta secante (2 punti di intersezione)",
   idea:"💡 Sostituisci y=x+1 nell'equazione della circonferenza e risolvi l'equazione di 2° grado risultante.",
   steps:[
     {ti:"Sostituisci la retta",tx:"x²+(x+1)²=8 → x²+x²+2x+1=8 → 2x²+2x−7=0.",hi:"Sostituire y elimina una variabile e ottieni un'equazione in solo x."},
     {ti:"Calcola il discriminante",tx:"Δ=b²−4ac=4+4·2·7=4+56=60>0.",hi:"Δ>0 garantisce due soluzioni reali distinte, cioè due intersezioni."},
     {ti:"Trova le intersezioni",tx:"x=(−2±√60)/4=(−1±√15)/2. Due punti reali distinti.",hi:"Non serve calcolare esattamente i valori: la condizione Δ>0 è sufficiente."},
     {ti:"Conclusione",tx:"Δ=60>0 → la retta è secante alla circonferenza. ✓",hi:"Se avessi trovato Δ=0: tangente. Δ<0: retta esterna (nessuna intersezione reale)."},
   ]},
  {id:21,title:"Ellisse centrata nell'origine",cat:"Le Coniche",diff:2,
   stmt:"L'ellisse x²/a²+y²/b²=1 (a>b>0) ha semi-asse maggiore a sull'asse x, semi-asse minore b sull'asse y, e fuochi F(±c,0) con c=√(a²−b²).",
   hyp:"x²/16+y²/9=1",tesi:"a=4, b=3, c=√7, fuochi F(±√7, 0)",
   idea:"💡 Leggi a² e b² direttamente dall'equazione, poi calcola c con la relazione c²=a²−b².",
   steps:[
     {ti:"Leggi i semi-assi",tx:"a²=16 → a=4; b²=9 → b=3. Semi-asse maggiore a=4 (asse x), minore b=3 (asse y).",hi:"Il semi-asse maggiore corrisponde al denominatore più grande."},
     {ti:"Calcola c",tx:"c²=a²−b²=16−9=7 → c=√7≈2.65.",hi:"c è la distanza dal centro ai fuochi. Si ha sempre a>c>0 per l'ellisse."},
     {ti:"Posizione dei fuochi",tx:"I fuochi stanno sull'asse del semi-asse maggiore (asse x): F₁(√7,0) e F₂(−√7,0).",hi:"Se a²>b² l'asse maggiore è orizzontale; se b²>a² è verticale."},
     {ti:"Verifica con vertice",tx:"Vertice A(4,0): 16/16+0/9=1 ✓. Vertice B(0,3): 0/16+9/9=1 ✓.",hi:"I vertici dell'ellisse sono (±a,0) e (0,±b)."},
   ]},
  {id:22,title:"Ellisse traslata",cat:"Le Coniche",diff:2,
   stmt:"L'ellisse con centro C(h,k) ha equazione (x−h)²/a²+(y−k)²/b²=1. Si ottiene traslando l'ellisse standard sostituendo x→(x−h) e y→(y−k).",
   hyp:"(x−1)²/9+(y+2)²/4=1",tesi:"Centro C(1,−2), a=3, b=2, fuochi F(1±√5,−2)",
   idea:"💡 Identifica h e k dai quadrati, poi applica le stesse formule dell'ellisse centrata nell'origine.",
   steps:[
     {ti:"Identifica il centro",tx:"(x−1)²→h=1; (y+2)²=(y−(−2))²→k=−2. Centro C(1,−2).",hi:"Il centro è il punto che azzera entrambi i quadrati: x=h, y=k."},
     {ti:"Leggi i semi-assi",tx:"a²=9→a=3 (asse orizzontale locale); b²=4→b=2.",hi:"a²>b²: l'asse maggiore è parallelo all'asse x."},
     {ti:"Calcola c",tx:"c²=9−4=5 → c=√5. Fuochi F(1±√5,−2).",hi:"I fuochi si trovano a distanza c dal centro lungo l'asse maggiore (orizzontale)."},
   ]},
  {id:23,title:"Iperbole centrata nell'origine",cat:"Le Coniche",diff:2,
   stmt:"L'iperbole x²/a²−y²/b²=1 ha centro O, vertici V(±a,0) e asintoti y=±(b/a)x. I fuochi sono F(±c,0) con c=√(a²+b²).",
   hyp:"x²/4−y²/9=1",tesi:"a=2, b=3, c=√13, asintoti y=±(3/2)x",
   idea:"💡 Leggi a² e b², poi calcola c con c²=a²+b² (nota: il segno è + per l'iperbole, non −).",
   steps:[
     {ti:"Leggi a e b",tx:"a²=4→a=2; b²=9→b=3. Vertici V(±2,0).",hi:"Per l'iperbole x²/a²−y²/b²=1, i vertici sono sull'asse x."},
     {ti:"Asintoti",tx:"y=±(b/a)x=±(3/2)x.",hi:"Gli asintoti non vengono mai toccati dall'iperbole ma le 'guidano' all'infinito."},
     {ti:"Calcola c",tx:"c²=a²+b²=4+9=13 → c=√13. Fuochi F(±√13,0).",hi:"Per l'iperbole c²=a²+b² (diverso dall'ellisse dove c²=a²−b²)."},
     {ti:"Verifica con il vertice",tx:"V(2,0): 4/4−0/9=1 ✓.",hi:"I vertici dell'iperbole soddisfano sempre l'equazione."},
   ]},
  {id:24,title:"Iperbole traslata",cat:"Le Coniche",diff:2,
   stmt:"L'iperbole con centro C(h,k) ha equazione (x−h)²/a²−(y−k)²/b²=1. Gli asintoti passano per C con pendenza ±b/a.",
   hyp:"(x+1)²/9−(y−2)²/4=1",tesi:"Centro C(−1,2), asintoti: y−2=±(2/3)(x+1)",
   idea:"💡 Identifica il centro dagli spostamenti, poi applica le stesse regole dell'iperbole standard.",
   steps:[
     {ti:"Identifica il centro",tx:"(x+1)²=(x−(−1))²→h=−1; (y−2)²→k=2. Centro C(−1,2).",hi:"Il centro è sempre il punto (h,k) che annulla entrambi i quadrati."},
     {ti:"Leggi a e b",tx:"a²=9→a=3; b²=4→b=2.",hi:""},
     {ti:"Scrivi gli asintoti traslati",tx:"y−k=±(b/a)(x−h) → y−2=±(2/3)(x+1).",hi:"Gli asintoti dell'iperbole traslata passano per il centro C(h,k)."},
   ]},
  {id:25,title:"Funzione omografica",cat:"Le Coniche",diff:2,
   stmt:"La funzione y=(ax+b)/(cx+d) ha dominio ℝ∖{−d/c}, asintoto verticale x=−d/c, asintoto orizzontale y=a/c. Il suo grafico è un'iperbole equilatera.",
   hyp:"y=(2x+1)/(x−3)",tesi:"Asintoto verticale x=3, asintoto orizzontale y=2",
   idea:"💡 Il denominatore nullo dà l'asintoto verticale; per l'orizzontale guarda il rapporto tra i coefficienti di x.",
   steps:[
     {ti:"Dominio",tx:"x−3≠0 → x≠3. Dominio: ℝ∖{3}.",hi:"L'asintoto verticale è proprio il valore escluso dal dominio."},
     {ti:"Asintoto verticale",tx:"x=3 (denominatore=0).",hi:""},
     {ti:"Asintoto orizzontale",tx:"Per x→±∞: y→(2x)/(x)=2. Asintoto orizzontale: y=2.",hi:"Considera solo i termini di grado più alto a numeratore e denominatore."},
     {ti:"Verifica con un punto",tx:"x=0: y=(0+1)/(0−3)=−1/3. Punto (0,−1/3) sul grafico.",hi:""},
     {ti:"Grafico",tx:"Iperbole con rami nei quadranti relativi al centro (3,2). Per x>3, y>2; per x<3, y<2 (ramo basso).",hi:"Il grafico non attraversa mai le asintotiche x=3 e y=2."},
   ]},
];

