import { useState } from "react";

const TR = "all 0.4s ease";
const hi  = (on, c="#ef4444", off="#cbd5e1") => on ? c : off;
const hiF = (on, c="rgba(239,68,68,0.15)", off="transparent") => on ? c : off;

/* ── Geometric primitives (same family as App_1) ───────── */
function Tick({x1,y1,x2,y2,n=1,stroke="#3b82f6",sw=2.2}){
  const cx=(x1+x2)/2,cy=(y1+y2)/2,dx=x2-x1,dy=y2-y1,l=Math.sqrt(dx*dx+dy*dy);
  const px=-dy/l*7,py=dx/l*7;
  return Array.from({length:n},(_,i)=>{const o=(i-(n-1)/2)*5,tx=cx+dx/l*o,ty=cy+dy/l*o;
    return <line key={i} x1={tx+px} y1={ty+py} x2={tx-px} y2={ty-py} stroke={stroke} strokeWidth={sw} strokeLinecap="round"/>;});
}
function RA({x,y,s=8,r=0,stroke="#64748b"}){
  return <g transform={`rotate(${r},${x},${y})`}><polyline points={`${x-s},${y} ${x-s},${y-s} ${x},${y-s}`} fill="none" stroke={stroke} strokeWidth="1.6"/></g>;
}
const Pt=({x,y,label,dx=4,dy=-6,fill="#374151",r=3,fs=11})=><><circle cx={x} cy={y} r={r} fill={fill}/>{label&&<text x={x+dx} y={y+dy} fill={fill} fontSize={fs} fontFamily="Georgia,serif" fontWeight="600">{label}</text>}</>;
const Lbl=({x,y,children,fill="#374151",fw="normal",fs=12,ta="start"})=><text x={x} y={y} fill={fill} fontSize={fs} fontFamily="Georgia,serif" fontWeight={fw} textAnchor={ta}>{children}</text>;

/* Cartesian axes helper. ox,oy: origin in pixels. ux,uy: pixels per unit. */
function Axes({ox,oy,xMin,xMax,yMin,yMax,ux=20,uy=20,grid=false,unit=true}){
  const xL=ox+xMin*ux, xR=ox+xMax*ux;
  const yT=oy-yMax*uy, yB=oy-yMin*uy;
  const ticks=[];
  if(unit){
    for(let x=Math.ceil(xMin);x<=Math.floor(xMax);x++) if(x!==0)
      ticks.push(<line key={`xt${x}`} x1={ox+x*ux} y1={oy-2.5} x2={ox+x*ux} y2={oy+2.5} stroke="#cbd5e1" strokeWidth="1"/>);
    for(let y=Math.ceil(yMin);y<=Math.floor(yMax);y++) if(y!==0)
      ticks.push(<line key={`yt${y}`} x1={ox-2.5} y1={oy-y*uy} x2={ox+2.5} y2={oy-y*uy} stroke="#cbd5e1" strokeWidth="1"/>);
  }
  return <g>
    {grid&&Array.from({length:Math.floor(xMax)-Math.ceil(xMin)+1},(_,i)=>{const x=Math.ceil(xMin)+i;
      return <line key={`gx${i}`} x1={ox+x*ux} y1={yT} x2={ox+x*ux} y2={yB} stroke="#f1f5f9" strokeWidth="0.8"/>;})}
    {grid&&Array.from({length:Math.floor(yMax)-Math.ceil(yMin)+1},(_,i)=>{const y=Math.ceil(yMin)+i;
      return <line key={`gy${i}`} x1={xL} y1={oy-y*uy} x2={xR} y2={oy-y*uy} stroke="#f1f5f9" strokeWidth="0.8"/>;})}
    <line x1={xL} y1={oy} x2={xR} y2={oy} stroke="#94a3b8" strokeWidth="1.3"/>
    <line x1={ox} y1={yT} x2={ox} y2={yB} stroke="#94a3b8" strokeWidth="1.3"/>
    <polygon points={`${xR},${oy} ${xR-5},${oy-3} ${xR-5},${oy+3}`} fill="#94a3b8"/>
    <polygon points={`${ox},${yT} ${ox-3},${yT+5} ${ox+3},${yT+5}`} fill="#94a3b8"/>
    {ticks}
    <text x={xR-2} y={oy+12} fontSize="10" fill="#94a3b8" fontFamily="Georgia,serif" fontStyle="italic" textAnchor="end">x</text>
    <text x={ox-6} y={yT+8} fontSize="10" fill="#94a3b8" fontFamily="Georgia,serif" fontStyle="italic">y</text>
    <text x={ox-5} y={oy+11} fontSize="9" fill="#94a3b8" fontFamily="Georgia,serif" textAnchor="end">O</text>
  </g>;
}

/* Quadratic Bezier path for a parabola y=ax²+bx+c from x1 to x2 */
function paraPath(a,b,c,x1,x2,ox,oy,ux,uy){
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const y1=a*x1*x1+b*x1+c, y2=a*x2*x2+b*x2+c;
  const xc=(x1+x2)/2, yc=a*x1*x2+b*(x1+x2)/2+c;
  return `M${X(x1).toFixed(1)},${Y(y1).toFixed(1)} Q${X(xc).toFixed(1)},${Y(yc).toFixed(1)} ${X(x2).toFixed(1)},${Y(y2).toFixed(1)}`;
}

/* ── FIGURES ─────────────────────────────────────────── */

/* 1 · Distanza tra due punti — A(1,1), B(4,3) */
const Fig1=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=35,oy=170,ux=30,uy=30;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const Ax=X(1),Ay=Y(1),Bx=X(4),By=Y(3);
  const dx=t>=0,dy=t>=1,tri=t>=2,hyp=t>=3,res=t>=4||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-0.3} xMax={5.5} yMin={-0.3} yMax={4} ux={ux} uy={uy} grid/>
    {tri&&<polygon points={`${Ax},${Ay} ${Bx},${Ay} ${Bx},${By}`} fill="rgba(59,130,246,0.10)" style={{transition:TR}}/>}
    <line x1={Ax} y1={Ay} x2={Bx} y2={Ay} stroke={hi(dx,"#f97316")} strokeWidth={dx?2.5:0} strokeLinecap="round" style={{transition:TR}}/>
    <line x1={Bx} y1={Ay} x2={Bx} y2={By} stroke={hi(dy,"#10b981")} strokeWidth={dy?2.5:0} strokeLinecap="round" style={{transition:TR}}/>
    <line x1={Ax} y1={Ay} x2={Bx} y2={By} stroke={hi(hyp,"#ef4444")} strokeWidth={hyp?2.8:0} strokeLinecap="round" style={{transition:TR}}/>
    {tri&&<RA x={Bx} y={Ay} s={8} r={180}/>}
    {dx&&<Lbl x={(Ax+Bx)/2-6} y={Ay+15} fill="#ea580c" fw="700">Δx=3</Lbl>}
    {dy&&<Lbl x={Bx+5} y={(Ay+By)/2+4} fill="#059669" fw="700">Δy=2</Lbl>}
    {hyp&&<Lbl x={(Ax+Bx)/2-22} y={(Ay+By)/2-4} fill="#dc2626" fw="700">d=√13</Lbl>}
    <Pt x={Ax} y={Ay} label="A(1,1)" dx={-30} dy={-6} fill="#1e293b"/>
    <Pt x={Bx} y={By} label="B(4,3)" dx={5} dy={-4} fill="#1e293b"/>
    {res&&<Lbl x={10} y={20} fill="#10b981" fw="700">d ≈ 3.61 ✓</Lbl>}
  </svg>;
};

/* 2 · Punto medio — A(-2,2), B(4,-2) */
const Fig2=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=110,oy=95,ux=18,uy=18;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const Ax=X(-2),Ay=Y(2),Bx=X(4),By=Y(-2),Mx=X(1),My=Y(0);
  const sX=t>=0,sY=t>=1,fin=t>=2||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-4} xMax={5.5} yMin={-3.5} yMax={3.5} ux={ux} uy={uy} grid/>
    <line x1={Ax} y1={Ay} x2={Bx} y2={By} stroke="#7c3aed" strokeWidth="2.2" strokeLinecap="round"/>
    {sX&&<line x1={Ax} y1={Ay+30} x2={Bx} y2={By+30} stroke="#f97316" strokeWidth="1.6" strokeDasharray="4,3" opacity="0.6"/>}
    <Pt x={Ax} y={Ay} label="A(−2,2)" dx={-50} dy={-5} fill="#1e293b"/>
    <Pt x={Bx} y={By} label="B(4,−2)" dx={5} dy={14} fill="#1e293b"/>
    {fin&&<Pt x={Mx} y={My} label="M(1,0)" dx={5} dy={-7} fill="#dc2626" r={4}/>}
    {sX&&<Lbl x={5} y={172} fill="#ea580c" fw="700" fs={11}>x_M = (−2+4)/2 = 1</Lbl>}
    {sY&&<Lbl x={5} y={185} fill="#059669" fw="700" fs={11}>y_M = (2−2)/2 = 0</Lbl>}
    {fin&&<Lbl x={155} y={20} fill="#10b981" fw="700">M(1,0) ✓</Lbl>}
  </svg>;
};

/* 3 · Perimetro triangolo — A(1,1), B(5,1), C(5,4) */
const Fig3=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=30,oy=170,ux=28,uy=28;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const Ax=X(1),Ay=Y(1),Bx=X(5),By=Y(1),Cx=X(5),Cy=Y(4);
  const ab=t>=0,bc=t>=1,ca=t>=2,fin=t===3||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-0.3} xMax={6} yMin={-0.3} yMax={5} ux={ux} uy={uy} grid/>
    <polygon points={`${Ax},${Ay} ${Bx},${By} ${Cx},${Cy}`} fill="rgba(234,88,12,0.08)" stroke="#94a3b8" strokeWidth="1"/>
    <line x1={Ax} y1={Ay} x2={Bx} y2={By} stroke={hi(ab,"#3b82f6")} strokeWidth={ab?3:1.5} strokeLinecap="round" style={{transition:TR}}/>
    <line x1={Bx} y1={By} x2={Cx} y2={Cy} stroke={hi(bc,"#10b981")} strokeWidth={bc?3:1.5} strokeLinecap="round" style={{transition:TR}}/>
    <line x1={Cx} y1={Cy} x2={Ax} y2={Ay} stroke={hi(ca,"#dc2626")} strokeWidth={ca?3:1.5} strokeLinecap="round" style={{transition:TR}}/>
    {ab&&<Lbl x={(Ax+Bx)/2-12} y={Ay+16} fill="#2563eb" fw="700">AB=4</Lbl>}
    {bc&&<Lbl x={Bx+5} y={(By+Cy)/2+4} fill="#059669" fw="700">BC=3</Lbl>}
    {ca&&<Lbl x={(Ax+Cx)/2-32} y={(Ay+Cy)/2-2} fill="#dc2626" fw="700">CA=5</Lbl>}
    <Pt x={Ax} y={Ay} label="A(1,1)" dx={-32} dy={14} fill="#1e293b"/>
    <Pt x={Bx} y={By} label="B(5,1)" dx={5} dy={14} fill="#1e293b"/>
    <Pt x={Cx} y={Cy} label="C(5,4)" dx={5} dy={-4} fill="#1e293b"/>
    {fin&&<Lbl x={50} y={28} fill="#10b981" fw="700">p = 12 unità ✓</Lbl>}
  </svg>;
};

/* 4 · Diagonali parallelogramma — A(0,0), B(4,0), C(5,3), D(1,3) */
const Fig4=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=30,oy=170,ux=28,uy=28;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const Ax=X(0),Ay=Y(0),Bx=X(4),By=Y(0),Cx=X(5),Cy=Y(3),Dx=X(1),Dy=Y(3);
  const Mx=X(2.5),My=Y(1.5);
  const diag=t>=0,mac=t>=1,mbd=t>=2,fin=t===3||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-0.3} xMax={6.5} yMin={-0.3} yMax={4} ux={ux} uy={uy} grid/>
    <polygon points={`${Ax},${Ay} ${Bx},${By} ${Cx},${Cy} ${Dx},${Dy}`} fill="rgba(124,58,237,0.08)" stroke="#475569" strokeWidth="2"/>
    <line x1={Ax} y1={Ay} x2={Cx} y2={Cy} stroke={hi(diag,"#ef4444")} strokeWidth={diag?2.2:0} strokeDasharray="6,3" style={{transition:TR}}/>
    <line x1={Bx} y1={By} x2={Dx} y2={Dy} stroke={hi(diag,"#3b82f6")} strokeWidth={diag?2.2:0} strokeDasharray="6,3" style={{transition:TR}}/>
    {mac&&<Pt x={Mx} y={My} fill="#dc2626" r={4}/>}
    {mbd&&<Pt x={Mx} y={My} fill="#2563eb" r={6}/>}
    {fin&&<Pt x={Mx} y={My} fill="#10b981" r={5}/>}
    <Pt x={Ax} y={Ay} label="A(0,0)" dx={-32} dy={14} fill="#1e293b"/>
    <Pt x={Bx} y={By} label="B(4,0)" dx={3} dy={14} fill="#1e293b"/>
    <Pt x={Cx} y={Cy} label="C(5,3)" dx={5} dy={-4} fill="#1e293b"/>
    <Pt x={Dx} y={Dy} label="D(1,3)" dx={-32} dy={-4} fill="#1e293b"/>
    {mac&&<Lbl x={120} y={20} fill="#dc2626" fw="700" fs={11}>M(AC) = (2.5, 1.5)</Lbl>}
    {mbd&&<Lbl x={120} y={32} fill="#2563eb" fw="700" fs={11}>M(BD) = (2.5, 1.5)</Lbl>}
    {fin&&<Lbl x={120} y={50} fill="#10b981" fw="700" fs={11}>Coincidono ✓</Lbl>}
  </svg>;
};

/* 5 · Equazione retta y=mx+q (esempio y=2x+1) */
const Fig5=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=120,oy=110,ux=22,uy=22;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const m=2,q=1;
  const showQ=t>=0,showM=t>=1,verify=t===3||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-3} xMax={3} yMin={-3} yMax={3.5} ux={ux} uy={uy} grid/>
    <line x1={X(-2)} y1={Y(m*(-2)+q)} x2={X(1.2)} y2={Y(m*1.2+q)} stroke="#2563eb" strokeWidth="2.5" strokeLinecap="round"/>
    {showM&&<><line x1={X(0)} y1={Y(1)} x2={X(1)} y2={Y(1)} stroke="#f97316" strokeWidth="2"/>
      <line x1={X(1)} y1={Y(1)} x2={X(1)} y2={Y(3)} stroke="#10b981" strokeWidth="2"/>
      <Lbl x={X(0.5)-6} y={Y(1)+13} fill="#ea580c" fw="700" fs={10}>+1</Lbl>
      <Lbl x={X(1)+4} y={Y(2)+3} fill="#059669" fw="700" fs={10}>+2</Lbl></>}
    {showQ&&<Pt x={X(0)} y={Y(q)} label="(0, q=1)" dx={6} dy={-5} fill="#dc2626" r={4}/>}
    <Lbl x={X(1.3)+4} y={Y(m*1.3+q)+4} fill="#2563eb" fw="700">y=2x+1</Lbl>
    {showM&&<Lbl x={X(1)+10} y={Y(2)-12} fill="#7c3aed" fw="700" fs={11}>m = 2</Lbl>}
    {verify&&<><Pt x={X(1)} y={Y(3)} fill="#10b981" r={4}/><Lbl x={10} y={20} fill="#10b981" fw="700" fs={11}>(1, 3): 2·1+1=3 ✓</Lbl></>}
  </svg>;
};

/* 6 · Calcolo pendenza — P1(0,1), P2(2,5) */
const Fig6=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=80,oy=160,ux=28,uy=22;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const dy=t>=1,dx=t>=2,res=t>=3,fin=t===4||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-1} xMax={5} yMin={-0.5} yMax={6.5} ux={ux} uy={uy} grid/>
    <line x1={X(-0.5)} y1={Y(2*(-0.5)+1)} x2={X(3)} y2={Y(2*3+1)} stroke="#2563eb" strokeWidth="2.5" strokeLinecap="round"/>
    <line x1={X(0)} y1={Y(1)} x2={X(2)} y2={Y(1)} stroke={hi(dx,"#f97316")} strokeWidth={dx?2.5:0} style={{transition:TR}}/>
    <line x1={X(2)} y1={Y(1)} x2={X(2)} y2={Y(5)} stroke={hi(dy,"#10b981")} strokeWidth={dy?2.5:0} style={{transition:TR}}/>
    {dx&&<Lbl x={X(1)-8} y={Y(1)+14} fill="#ea580c" fw="700" fs={11}>Δx=2</Lbl>}
    {dy&&<Lbl x={X(2)+5} y={Y(3)+4} fill="#059669" fw="700" fs={11}>Δy=4</Lbl>}
    <Pt x={X(0)} y={Y(1)} label="P₁(0,1)" dx={-46} dy={4} fill="#1e293b"/>
    <Pt x={X(2)} y={Y(5)} label="P₂(2,5)" dx={5} dy={-4} fill="#1e293b"/>
    {res&&<Lbl x={120} y={28} fill="#7c3aed" fw="700" fs={13}>m = 4/2 = 2</Lbl>}
    {fin&&<Lbl x={120} y={45} fill="#10b981" fw="700" fs={11}>retta crescente ✓</Lbl>}
  </svg>;
};

/* 7 · Retta per due punti — A(1,3), B(4,-3) → y=-2x+5 */
const Fig7=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=50,oy=100,ux=22,uy=20;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const showM=t>=0,line=t>=2,verify=t===3||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-1} xMax={6} yMin={-4} yMax={5} ux={ux} uy={uy} grid/>
    {line&&<line x1={X(-0.2)} y1={Y(-2*(-0.2)+5)} x2={X(5.5)} y2={Y(-2*5.5+5)} stroke="#2563eb" strokeWidth="2.5" strokeLinecap="round" style={{transition:TR}}/>}
    {showM&&!line&&<><line x1={X(1)} y1={Y(3)} x2={X(4)} y2={Y(3)} stroke="#f97316" strokeWidth="2"/>
      <line x1={X(4)} y1={Y(3)} x2={X(4)} y2={Y(-3)} stroke="#10b981" strokeWidth="2"/>
      <Lbl x={X(2.5)-8} y={Y(3)-5} fill="#ea580c" fw="700" fs={10}>Δx=3</Lbl>
      <Lbl x={X(4)+5} y={Y(0)+4} fill="#059669" fw="700" fs={10}>Δy=−6</Lbl></>}
    <Pt x={X(1)} y={Y(3)} label="A(1,3)" dx={-46} dy={-3} fill="#1e293b"/>
    <Pt x={X(4)} y={Y(-3)} label="B(4,−3)" dx={5} dy={14} fill="#1e293b"/>
    {showM&&<Lbl x={130} y={20} fill="#7c3aed" fw="700" fs={11}>m = −6/3 = −2</Lbl>}
    {verify&&<Lbl x={130} y={35} fill="#10b981" fw="700" fs={11}>y = −2x + 5 ✓</Lbl>}
  </svg>;
};

/* 8 · Parallele e perpendicolari */
const Fig8=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=120,oy=100,ux=18,uy=18;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const par=t===0,perp=t===1,fin=t>=2||t===99;
  const showPar=par||fin, showPerp=perp||fin;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-5} xMax={5} yMin={-4} yMax={4} ux={ux} uy={uy} grid/>
    <line x1={X(-3)} y1={Y(2*(-3)+1)} x2={X(2)} y2={Y(2*2+1)} stroke={hi(showPar,"#2563eb","#cbd5e1")} strokeWidth={showPar?2.5:1.5} strokeLinecap="round" style={{transition:TR}}/>
    <line x1={X(-2)} y1={Y(2*(-2)-3)} x2={X(3)} y2={Y(2*3-3)} stroke={hi(showPar,"#2563eb","#cbd5e1")} strokeWidth={showPar?2.5:1.5} strokeLinecap="round" style={{transition:TR}}/>
    <line x1={X(-3)} y1={Y(2*(-3))} x2={X(3)} y2={Y(2*3)} stroke={hi(showPerp,"#dc2626","#cbd5e1")} strokeWidth={showPerp?2.5:1.5} strokeLinecap="round" style={{transition:TR}}/>
    <line x1={X(-3)} y1={Y(-(-3)/2)} x2={X(3)} y2={Y(-3/2)} stroke={hi(showPerp,"#dc2626","#cbd5e1")} strokeWidth={showPerp?2.5:1.5} strokeLinecap="round" style={{transition:TR}}/>
    {showPar&&<><Lbl x={X(2)+4} y={Y(5)+5} fill="#2563eb" fw="700" fs={10}>m=2</Lbl><Lbl x={X(3)+4} y={Y(3)+5} fill="#2563eb" fw="700" fs={10}>m=2</Lbl></>}
    {showPerp&&<><Lbl x={X(-3)-4} y={Y(-5.5)} fill="#dc2626" fw="700" fs={10}>m=2</Lbl><Lbl x={X(3)+4} y={Y(-1.5)+4} fill="#dc2626" fw="700" fs={10}>m=−½</Lbl></>}
    {par&&<Lbl x={10} y={20} fill="#2563eb" fw="700" fs={12}>PARALLELE: m₁ = m₂</Lbl>}
    {perp&&<Lbl x={10} y={20} fill="#dc2626" fw="700" fs={12}>PERPENDICOLARI: m₁·m₂ = −1</Lbl>}
    {fin&&<Lbl x={10} y={20} fill="#10b981" fw="700" fs={11}>2·(−½) = −1 ✓</Lbl>}
  </svg>;
};

/* 9 · Distanza punto-retta — P(3,3), 2x+y-2=0 */
const Fig9=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=80,oy=110,ux=20,uy=18;
  const X=x=>ox+x*ux, Y=y=>oy-y*uy;
  const Px=X(3),Py=Y(3);
  const Hx=X(0.2),Hy=Y(1.6);
  const showP=t>=0,coeff=t>=1,perp=t>=2,fin=t===3||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-3} xMax={6} yMin={-3} yMax={4} ux={ux} uy={uy} grid/>
    <line x1={X(-1)} y1={Y(-2*(-1)+2)} x2={X(3)} y2={Y(-2*3+2)} stroke="#2563eb" strokeWidth="2.5" strokeLinecap="round"/>
    <Lbl x={X(-1)+4} y={Y(4)} fill="#2563eb" fw="700" fs={11}>2x+y−2=0</Lbl>
    <Pt x={Px} y={Py} label="P(3,3)" dx={5} dy={-4} fill="#1e293b"/>
    {perp&&<line x1={Px} y1={Py} x2={Hx} y2={Hy} stroke="#dc2626" strokeWidth="1.8" strokeDasharray="5,3" style={{transition:TR}}/>}
    {fin&&<Pt x={Hx} y={Hy} fill="#dc2626" r={3}/>}
    {coeff&&<Lbl x={130} y={150} fill="#7c3aed" fw="700" fs={11}>a=2, b=1, c=−2</Lbl>}
    {fin&&<Lbl x={130} y={170} fill="#10b981" fw="700" fs={11}>d = 7/√5 ≈ 3.13 ✓</Lbl>}
  </svg>;
};

