    {showCircle&&<circle cx={Cpx} cy={Cpy} r={rPx} fill="rgba(8,145,178,0.10)" stroke="#0891b2" strokeWidth="2.2"/>}
    {showC&&<Pt x={Cpx} y={Cpy} label="C(2,−3)" dx={5} dy={-5} fill="#dc2626" r={4}/>}
