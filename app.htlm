    {sC&&<Lbl x={140} y={48} fill="#10b981" fw="700" fs={10}>a − b = 5</Lbl>}
    {sol&&<Lbl x={140} y={62} fill="#7c3aed" fw="700" fs={10}>a=1, b=−4</Lbl>}
    {fin&&<Lbl x={130} y={180} fill="#10b981" fw="700" fs={11}>y=x²−4x+3 ✓</Lbl>}
  </svg>;
};

/* 16 · Tangente e normale — T(1,3) su y=x²+2, m_t=2, m_n=-1/2 */
const Fig16=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=120,oy=170,ux=22,uy=20;
