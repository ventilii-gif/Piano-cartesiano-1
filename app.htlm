};
const DL=["","★ Base","★★ Intermedio","★★★ Avanzato"];
const DC=["","#16a34a","#d97706","#dc2626"];



const QUIZZES=[
  /* ── Piano Cartesiano · 10 Teorici ─────────────────── */
  {id:"pc1",cat:"Piano Cartesiano",type:"T",
   q:"Quale formula calcola la distanza tra A(x₁,y₁) e B(x₂,y₂)?",
   opts:["(x₂−x₁)+(y₂−y₁)","√((x₂−x₁)²+(y₂−y₁)²)","((x₁+x₂)/2,(y₁+y₂)/2)","|x₂−x₁|·|y₂−y₁|"],
   ans:1,why:"La distanza è l'ipotenusa del triangolo rettangolo: teorema di Pitagora con cateti Δx e Δy.",
   wr:["Sommare le differenze non dà la lunghezza.","Questa è la formula del punto medio.","Il prodotto non è una distanza."]},
  {id:"pc3",cat:"Piano Cartesiano",type:"T",
   q:"La formula del punto medio M tra A(x₁,y₁) e B(x₂,y₂) è:",
   opts:["M=((x₁+x₂)/2,(y₁+y₂)/2)","M=(x₂−x₁,y₂−y₁)","M=(x₁·x₂,y₁·y₂)","M=((x₁−x₂)/2,(y₁−y₂)/2)"],
   ans:0,why:"Il punto medio ha coordinate pari alla media aritmetica delle coordinate dei due estremi.",
   wr:["Quella è lo spostamento (Δx,Δy).","Il prodotto non ha senso geometrico per il punto medio.","Dividere la differenza dà metà dello spostamento, non il medio."]},
  {id:"pc5",cat:"Piano Cartesiano",type:"T",
   q:"In quale quadrante si trova il punto P(−3, 5)?",
   opts:["I (x>0,y>0)","II (x<0,y>0)","III (x<0,y<0)","IV (x>0,y<0)"],
   ans:1,why:"x=−3<0 e y=5>0: II quadrante (ascissa negativa, ordinata positiva).",
   wr:["I quadrante: entrambe positive.","III: entrambe negative.","IV: x>0."]},
  {id:"pc7",cat:"Piano Cartesiano",type:"T",
   q:"Le diagonali di un parallelogramma si bisecano, cioè:",
   opts:["Si intersecano ad angolo retto","Si intersecano nel punto medio l'una dell'altra","Hanno la stessa lunghezza","Sono parallele"],
   ans:1,why:"Il punto d'incontro è il punto medio di entrambe le diagonali: proprietà caratteristica del parallelogramma.",
   wr:["Angoli retti solo in rettangoli e rombi.","Stessa lunghezza solo nei rettangoli.","Le diagonali si intersecano, non sono parallele."]},
  {id:"pc9",cat:"Piano Cartesiano",type:"T",
   q:"La distanza di un punto P(x,y) dall'origine O(0,0) è:",
   opts:["√(x+y)","x+y","√(x²+y²)","x²+y²"],
   ans:2,why:"d(P,O)=√((x−0)²+(y−0)²)=√(x²+y²): formula della distanza con secondo estremo in O.",
   wr:["√(x+y): serve la somma dei quadrati.","x+y: somma coordinate, non distanza.","x²+y² è il quadrato della distanza."]},
  {id:"pc11",cat:"Piano Cartesiano",type:"T",
   q:"L'area del triangolo con vertici A(x₁,y₁), B(x₂,y₂), C(x₃,y₃) si calcola con:",
   opts:["|x₁(y₂−y₃)+x₂(y₃−y₁)+x₃(y₁−y₂)|/2","base×altezza/2","√(s(s−a)(s−b)(s−c))","Δx·Δy/2"],
   ans:0,why:"La formula del determinante (shoelace) vale sempre per coordinate cartesiane.",
   wr:["base×altezza richiede di conoscere base e altezza separatamente.","La formula di Erone serve le lunghezze dei lati, non le coordinate.","Δx·Δy/2 vale solo per triangoli rettangoli con cateti paralleli agli assi."]},
  {id:"pc12",cat:"Piano Cartesiano",type:"T",
   q:"Tre punti A, B, C sono collineari se e solo se:",
   opts:["L'area del triangolo ABC è zero","Hanno la stessa ascissa","Le distanze AB+BC=AC","Hanno la stessa ordinata"],
   ans:0,why:"Area=0 significa che i tre punti non formano un triangolo: stanno sulla stessa retta.",
   wr:["Stessa ascissa: sono su una retta verticale, caso particolare.","AB+BC=AC è equivalente ma meno pratica da calcolare.","Stessa ordinata: retta orizzontale, caso particolare."]},
  {id:"pc13",cat:"Piano Cartesiano",type:"T",
   q:"Il punto simmetrico di P(x,y) rispetto all'origine O è:",
   opts:["(−x,−y)","(x,−y)","(−x,y)","(y,x)"],
   ans:0,why:"La simmetria rispetto all'origine inverte il segno di entrambe le coordinate.",
   wr:["(x,−y): questa è la simmetria rispetto all'asse x.","(−x,y): simmetria rispetto all'asse y.","(y,x): scambio delle coordinate, non simmetria rispetto a O."]},
  {id:"pc14",cat:"Piano Cartesiano",type:"T",
   q:"Il punto simmetrico di P(x,y) rispetto all'asse x è:",
   opts:["(x,−y)","(−x,y)","(−x,−y)","(y,x)"],
   ans:0,why:"La simmetria rispetto all'asse x conserva l'ascissa e cambia segno all'ordinata.",
   wr:["(−x,y): simmetria rispetto all'asse y.","(−x,−y): simmetria rispetto all'origine.","(y,x): scambio, non simmetria."]},
  {id:"pc15",cat:"Piano Cartesiano",type:"T",
   q:"La distanza di un punto P(x,y) dall'asse y è:",
   opts:["|x|","|y|","√(x²+y²)","x"],
   ans:0,why:"La distanza dall'asse y è la distanza orizzontale: vale |x|, il valore assoluto dell'ascissa.",
   wr:["|y| è la distanza dall'asse x.","√(x²+y²) è la distanza dall'origine.","x senza valore assoluto può essere negativo."]},
  /* ── Piano Cartesiano · 10 Numerici ────────────────── */
  {id:"pc2",cat:"Piano Cartesiano",type:"N",
   q:"Calcola d(A,B) con A(0,0) e B(3,4).",
   opts:["5","7","√7","12"],
   ans:0,why:"d=√(9+16)=√25=5. Triangolo pitagorico 3-4-5.",
   wr:["7=Δx+Δy, non distanza.","√7≈2.6: errato.","12=Δx·Δy."]},
  {id:"pc4",cat:"Piano Cartesiano",type:"N",
   q:"Punto medio di A(−2,4) e B(6,−2)?",
   opts:["M(2,1)","M(4,2)","M(2,2)","M(1,3)"],
   ans:0,why:"x_M=(−2+6)/2=2, y_M=(4−2)/2=1 → M(2,1).",
   wr:["y_M≠2.","Coordinate scambiate.","x_M=2, non 1."]},
  {id:"pc6",cat:"Piano Cartesiano",type:"N",
   q:"Perimetro del triangolo A(0,0), B(4,0), C(0,3)?",
   opts:["12","7","5","14"],
   ans:0,why:"AB=4, CA=3, BC=√(16+9)=5 → p=12.",
   wr:["7=AB+CA senza BC.","5 è solo BC.","14 errato."]},
  {id:"pc8",cat:"Piano Cartesiano",type:"N",
   q:"Distanza tra A(1,2) e B(4,6)?",
   opts:["5","7","√7","3"],
   ans:0,why:"Δx=3, Δy=4 → d=√(9+16)=5.",
   wr:["7=Δx+Δy.","√7 errato.","3 è solo Δx."]},
  {id:"pc10",cat:"Piano Cartesiano",type:"N",
   q:"M(3,−1) è il punto medio di A(1,3) e B(?,?)?",
   opts:["B(5,−5)","B(4,−4)","B(2,−2)","B(6,−4)"],
   ans:0,why:"x_B=2·3−1=5; y_B=2·(−1)−3=−5 → B(5,−5).",
   wr:["x_B≠4.","x_B≠2.","y_B≠−4."]},
  {id:"pc16",cat:"Piano Cartesiano",type:"N",
   q:"Area del triangolo A(0,0), B(6,0), C(0,4)?",
   opts:["12","24","10","8"],
   ans:0,why:"base=6, altezza=4 → Area=(6×4)/2=12.",
   wr:["24=base×altezza (senza /2).","10 errato.","8 errato."]},
  {id:"pc17",cat:"Piano Cartesiano",type:"N",
   q:"I punti A(0,0), B(2,4), C(1,2) sono collineari?",
   opts:["Sì","No, formano un triangolo","Impossibile saperlo","Solo A e B lo sono"],
   ans:0,why:"Area=|0(4−2)+2(2−0)+1(0−4)|/2=|0+4−4|/2=0 → collineari. Verifica: C sta su y=2x.",
   wr:["Area≠0 solo se non collineari.","Sempre possibile verificare con l'area.","La collinearità coinvolge tutti e tre."]},
  {id:"pc18",cat:"Piano Cartesiano",type:"N",
   q:"Simmetrico di P(3,−1) rispetto all'asse y?",
   opts:["(−3,−1)","(3,1)","(−3,1)","(1,−3)"],
   ans:0,why:"Rispetto all'asse y: x→−x, y→y → (−3,−1).",
   wr:["(3,1): simmetria rispetto all'asse x.","(−3,1): cambia anche y.","(1,−3): scambio coordinate."]},
  {id:"pc19",cat:"Piano Cartesiano",type:"N",
   q:"Simmetrico di P(2,−3) rispetto all'origine?",
   opts:["(−2,3)","(2,3)","(−2,−3)","(3,−2)"],
   ans:0,why:"Rispetto a O: (x,y)→(−x,−y) → (−2,3).",
   wr:["(2,3): cambia solo y.","(−2,−3): è il simmetrico rispetto all'asse y poi x.","(3,−2): scambio coordinate."]},
  {id:"pc20",cat:"Piano Cartesiano",type:"N",
   q:"Distanza di P(5,12) dall'origine?",
   opts:["13","17","√17","7"],
   ans:0,why:"d=√(25+144)=√169=13. Triangolo 5-12-13.",
   wr:["17=5+12.","√17≈4.1 errato.","7=12−5."]},
  /* ── La Retta · 10 Teorici ──────────────────────────── */
  {id:"r1",cat:"La Retta",type:"T",
   q:"In y=mx+q, cosa rappresenta q?",
   opts:["La pendenza","L'intercetta con l'asse y","L'intercetta con l'asse x","Il coefficiente di x²"],
   ans:1,why:"q è il valore di y per x=0: il punto in cui la retta taglia l'asse y.",
   wr:["m è la pendenza.","L'intercetta con l'asse x si trova ponendo y=0.","Le rette non hanno x²."]},
  {id:"r3",cat:"La Retta",type:"T",
   q:"Due rette sono parallele se e solo se:",
   opts:["Hanno la stessa intercetta q","Hanno la stessa pendenza m","Si intersecano in un punto","Sono perpendicolari"],
   ans:1,why:"Rette parallele: m₁=m₂ ma q₁≠q₂.",
   wr:["Stessa q e stessa m → coincidenti.","Rette che si intersecano non sono parallele.","Perpendicolari si intersecano."]},
  {id:"r5",cat:"La Retta",type:"T",
   q:"La condizione di perpendicolarità tra due rette è:",
   opts:["m₁=m₂","m₁+m₂=0","m₁·m₂=−1","m₁·m₂=1"],
   ans:2,why:"m₁·m₂=−1: le pendenze sono reciproche opposte.",
   wr:["m₁=m₂: parallelismo.","m₁+m₂=0: pendenze opposte, non perpendicolari.","m₁·m₂=1: non è la condizione."]},
  {id:"r7",cat:"La Retta",type:"T",
   q:"Quante rette passano per due punti distinti?",
   opts:["Infinite","Nessuna","Una sola","Due"],
   ans:2,why:"Per due punti distinti passa una sola retta: postulato della geometria euclidea.",
   wr:["Infinite: solo per un punto solo.","Esiste sempre almeno una.","Non due: è unica."]},
  {id:"r9",cat:"La Retta",type:"T",
   q:"Qual è la forma implicita generale di una retta?",
   opts:["y=mx+q","ax+by+c=0","y−y₀=m(x−x₀)","y=k"],
   ans:1,why:"ax+by+c=0 include anche le rette verticali (b=0).",
   wr:["Forma esplicita, esclude verticali.","Forma punto-pendenza.","Retta orizzontale, caso particolare."]},
  {id:"r11",cat:"La Retta",type:"T",
   q:"Come si trova l'intercetta sull'asse x di y=mx+q?",
   opts:["Poni y=0 e risolvi per x","Poni x=0","Calcola m","Calcola q/m"],
   ans:0,why:"Sull'asse x: y=0 → 0=mx+q → x=−q/m.",
   wr:["x=0 dà l'intercetta sull'asse y.","m è la pendenza, non l'intercetta.","q/m è uguale a −x_intercetta senza segno."]},
  {id:"r12",cat:"La Retta",type:"T",
   q:"La retta x=k (k costante) è:",
   opts:["Una retta verticale senza pendenza definita","Una retta con pendenza k","Una retta orizzontale","Una parabola"],
   ans:0,why:"x=k è verticale, parallela all'asse y. Δx=0 → pendenza non definita.",
   wr:["La pendenza sarebbe Δy/Δx, ma Δx=0.","y=k è l'orizzontale.","Le parabole hanno x²." ]},
  {id:"r13",cat:"La Retta",type:"T",
   q:"L'equazione della retta per l'origine con pendenza m è:",
   opts:["y=mx","y=m","x=m","y=mx+m"],
   ans:0,why:"Passando per O(0,0): 0=m·0+q → q=0 → y=mx.",
   wr:["y=m: retta orizzontale.","x=m: verticale.","y=mx+m: passa per (0,m), non per l'origine."]},
  {id:"r14",cat:"La Retta",type:"T",
   q:"La distanza del punto P(x₀,y₀) dalla retta ax+by+c=0 è:",
   opts:["|ax₀+by₀+c|/√(a²+b²)","|ax₀+by₀+c|","√(a²+b²)","(ax₀+by₀+c)²"],
   ans:0,why:"Il denominatore √(a²+b²) normalizza per la lunghezza del vettore normale alla retta.",
   wr:["|ax₀+by₀+c| manca la normalizzazione.","√(a²+b²) è il denominatore, non la distanza.","Il quadrato non è una distanza."]},
  {id:"r15",cat:"La Retta",type:"T",
   q:"Il fascio proprio di rette con centro P(x₀,y₀) è:",
   opts:["L'insieme di tutte le rette passanti per P","Le rette con stessa pendenza","Le rette parallele a una data","Le rette per l'origine"],
   ans:0,why:"Il fascio proprio di centro P è la famiglia di tutte le rette passanti per un punto fisso P.",
   wr:["Stessa pendenza: fascio improprio (parallele).","Fascio improprio: parallele.","Solo il caso particolare P=O."]},
  /* ── La Retta · 10 Numerici ─────────────────────────── */
  {id:"r2",cat:"La Retta",type:"N",
   q:"Pendenza della retta y=3x−5?",
   opts:["3","−5","5","−3"],
   ans:0,why:"m=3 (coefficiente di x).",
   wr:["−5 è q.","5=|q|.","−3: segno sbagliato."]},
  {id:"r4",cat:"La Retta",type:"N",
   q:"Equazione della retta per A(0,2) e B(2,6)?",
   opts:["y=2x+2","y=2x−2","y=3x+2","y=x+2"],
   ans:0,why:"m=(6−2)/(2−0)=2; q=2 → y=2x+2.",
   wr:["q≠−2.","m≠3.","m≠1."]},
  {id:"r6",cat:"La Retta",type:"N",
   q:"Distanza di P(0,0) dalla retta 3x+4y−10=0?",
   opts:["2","10","5","8"],
   ans:0,why:"d=|−10|/√(9+16)=10/5=2.",
   wr:["10 è solo il numeratore.","5 è il denominatore.","8 errato."]},
  {id:"r8",cat:"La Retta",type:"N",
   q:"Retta con m=−2 per (1,3): valore di q?",
   opts:["5","1","−1","−5"],
   ans:0,why:"3=−2·1+q → q=5.",
   wr:["q=1: errore algebrico.","q=−1: segno sbagliato.","q=−5: sbagliato."]},
  {id:"r10",cat:"La Retta",type:"N",
   q:"Le rette y=2x+1 e y=−x/2+3 sono:",
   opts:["Parallele","Perpendicolari","Coincidenti","Incidenti non perp."],
   ans:1,why:"m₁·m₂=2·(−1/2)=−1: perpendicolari.",
   wr:["Parallele: m₁=m₂.","Coincidenti: stessa equazione.","Prodotto=−1 → perpendicolari."]},
  {id:"r16",cat:"La Retta",type:"N",
   q:"Intercetta sull'asse x di y=2x−6?",
   opts:["x=3","x=−3","x=6","x=−6"],
   ans:0,why:"y=0 → 2x=6 → x=3.",
   wr:["x=−3: segno sbagliato.","x=6 è −q, non −q/m.","x=−6 errato."]},
  {id:"r17",cat:"La Retta",type:"N",
   q:"Pendenza della retta perpendicolare a y=−3x+2?",
   opts:["1/3","−1/3","3","−3"],
   ans:0,why:"m₁=−3 → m₂=−1/m₁=1/3.",
   wr:["−1/3: segno sbagliato.","3=−m₁, non −1/m₁.","−3=m₁, non la perpendicolare."]},
  {id:"r18",cat:"La Retta",type:"N",
   q:"Distanza tra le rette parallele y=2x+1 e y=2x−3?",
   opts:["4/√5","4","2","√5"],
   ans:0,why:"Forma implicita: 2x−y+1=0 e 2x−y−3=0. d=|1−(−3)|/√(4+1)=4/√5.",
   wr:["4 è il numeratore prima della divisione.","2=|Δq|/2 errato.","√5 è solo il denominatore."]},
  {id:"r19",cat:"La Retta",type:"N",
   q:"La retta y=x+3 interseca l'asse x in A e l'asse y in B. Punto medio di AB?",
   opts:["(−3/2, 3/2)","(3/2,−3/2)","(0,3)","(−3,0)"],
   ans:0,why:"A(−3,0), B(0,3). M=(−3/2, 3/2).",
   wr:["Coordinate scambiate.","B è un estremo, non il medio.","A è un estremo, non il medio."]},
  {id:"r20",cat:"La Retta",type:"N",
   q:"Retta per A(1,2) e B(3,2): equazione?",
   opts:["y=2","x=2","y=x+1","y=2x"],
   ans:0,why:"A e B hanno ordinata y=2: retta orizzontale y=2, pendenza m=0.",
   wr:["x=2: verticale; ma le ascisse sono diverse.","y=x+1: m=1 errato.","y=2x: non passa per A(1,2)? 2·1=2 ✓, ma per B? 2·3=6≠2."]},
  /* ── La Parabola · 10 Teorici ───────────────────────── */
  {id:"p1",cat:"La Parabola",type:"T",
   q:"L'asse di simmetria di y=ax²+bx+c è:",
   opts:["x=−b/(2a)","x=b/(2a)","y=−b/(2a)","x=−b/a"],
   ans:0,why:"L'asse di simmetria passa per il vertice: x_V=−b/(2a).",
   wr:["Manca il segno −.","y=... è orizzontale, non verticale.","Manca il fattore 2 al denominatore."]},
  {id:"p3",cat:"La Parabola",type:"T",
   q:"La parabola ha 2 zeri (interseca l'asse x in 2 punti distinti) se:",
   opts:["Δ=0","Δ>0","Δ<0","a>0"],
   ans:1,why:"Δ=b²−4ac>0: due soluzioni reali distinte.",
   wr:["Δ=0: un punto (tangente).","Δ<0: nessuna intersezione.","a>0 dà la concavità, non il numero di zeri."]},
  {id:"p5",cat:"La Parabola",type:"T",
   q:"Il vertice della parabola è:",
   opts:["L'intersezione con l'asse y","Il punto di minimo (a>0) o massimo (a<0)","Il punto x=0","Uno zero della funzione"],
   ans:1,why:"Il vertice è il punto estremale: minimo se a>0, massimo se a<0.",
   wr:["L'intersezione con y si chiama intercetta y.","x=0 dà y=c, l'intercetta y.","Gli zeri sono le radici, non il vertice."]},
  {id:"p7",cat:"La Parabola",type:"T",
   q:"Se a<0 nella parabola y=ax²+bx+c, allora:",
   opts:["Concava verso l'alto (∪)","Concava verso il basso (∩)","Priva di vertice","Simmetrica rispetto all'asse x"],
   ans:1,why:"a<0: parabola aperta in basso (∩).",
   wr:["∪ richiede a>0.","Ogni parabola ha sempre un vertice.","Simmetrica rispetto al proprio asse, non all'asse x."]},
  {id:"p9",cat:"La Parabola",type:"T",
   q:"La retta è tangente alla parabola quando il sistema ha:",
   opts:["Δ>0","Δ=0","Δ<0","Nessuna condizione"],
   ans:1,why:"Tangente = un solo punto di contatto = Δ=0.",
   wr:["Δ>0: secante (due intersezioni).","Δ<0: nessuna intersezione.","Il discriminante è la condizione chiave."]},
  {id:"p11",cat:"La Parabola",type:"T",
   q:"La forma canonica con vertice V(h,k) è:",
   opts:["y=a(x−h)²+k","y=ax²+bx+c","y−k=a(x−h)","y=(x−h)²+k"],
   ans:0,why:"La forma canonica traslata y=a(x−h)²+k mostra direttamente il vertice V(h,k).",
   wr:["Forma generale: non mostra subito il vertice.","y−k=a(x−h): manca l'elevamento al quadrato.","Manca il coefficiente a davanti al quadrato."]},
  {id:"p12",cat:"La Parabola",type:"T",
   q:"La parabola y=a(x−h)²+k ha il vertice:",
   opts:["V(h,k)","V(−h,−k)","V(h,−k)","V(−h,k)"],
   ans:0,why:"Per costruzione, il minimo/massimo è in x=h → y=k: V(h,k).",
   wr:["V(−h,−k): segni sbagliati.","V(h,−k): y_V=k, non −k.","V(−h,k): x_V=h, non −h."]},
  {id:"p13",cat:"La Parabola",type:"T",
   q:"Una parabola è tangente all'asse x quando:",
   opts:["Δ=0","Δ>0","Δ<0","a=0"],
   ans:0,why:"Tangente all'asse x: un solo punto di contatto con y=0 → Δ=0.",
   wr:["Δ>0: due intersezioni con l'asse x.","Δ<0: nessuna intersezione.","a=0: non è più una parabola."]},
  {id:"p14",cat:"La Parabola",type:"T",
   q:"Il numero massimo di intersezioni tra una retta e una parabola è:",
   opts:["2","1","3","0"],
   ans:0,why:"Sostituendo la retta ottieni un'equazione di 2° grado → max 2 soluzioni.",
   wr:["1: possibile (tangente), ma non il massimo.","3: impossibile per equazione di 2°.","0: possibile, ma non il massimo."]},
  {id:"p15",cat:"La Parabola",type:"T",
   q:"Se a>0 e Δ<0, la parabola:",
   opts:["Sta tutta sopra l'asse x","Sta tutta sotto l'asse x","Interseca l'asse x in 2 punti","È tangente all'asse x"],
   ans:0,why:"a>0: concava verso l'alto. Δ<0: nessuna radice reale → tutta sopra l'asse x.",
   wr:["Sotto: richiederebbe a<0 e Δ<0.","2 intersezioni: richiederebbe Δ>0.","Tangente: solo se Δ=0."]},
  /* ── La Parabola · 10 Numerici ──────────────────────── */
  {id:"p2",cat:"La Parabola",type:"N",
   q:"Vertice di y=x²−4x+3?",
   opts:["V(2,−1)","V(2,3)","V(−2,15)","V(4,3)"],
   ans:0,why:"x_V=2, y_V=4−8+3=−1.",
   wr:["y_V≠3.","x_V=2, non −2.","x_V=2, non 4."]},
  {id:"p4",cat:"La Parabola",type:"N",
   q:"Discriminante di y=x²−5x+4?",
   opts:["9","41","−9","25"],
   ans:0,why:"Δ=25−16=9.",
   wr:["41=25+16 (somma invece di differenza).","−9: Δ>0 in questo caso.","25=b² senza −4ac."]},
  {id:"p6",cat:"La Parabola",type:"N",
   q:"Asse di simmetria di y=2x²−8x+1?",
   opts:["x=2","x=−2","x=4","x=1"],
   ans:0,why:"x_V=8/4=2.",
   wr:["x=−2: risultato positivo.","x=4=b.","x=1 errato."]},
  {id:"p8",cat:"La Parabola",type:"N",
   q:"Intersezioni di y=x²−4 con l'asse x?",
   opts:["x=±2","x=2 solo","x=±4","x=0"],
   ans:0,why:"x²=4 → x=±2.",
   wr:["Due soluzioni.","√4=2, non 4.","y(0)=−4≠0."]},
  {id:"p10",cat:"La Parabola",type:"N",
   q:"Per quale k la retta y=x+k è tangente a y=x²?",
   opts:["k=−1/4","k=1/4","k=1","k=0"],
   ans:0,why:"Δ=1+4k=0 → k=−1/4.",
   wr:["k=1/4: Δ=2>0.","k=1: Δ=5>0.","k=0: Δ=1>0."]},
  {id:"p16",cat:"La Parabola",type:"N",
   q:"Vertice di y=2(x−3)²−1?",
   opts:["V(3,−1)","V(−3,1)","V(3,1)","V(−3,−1)"],
   ans:0,why:"Forma canonica y=a(x−h)²+k: h=3, k=−1.",
   wr:["Segni sbagliati.","y_V=−1, non 1.","x_V=3, non −3."]},
  {id:"p17",cat:"La Parabola",type:"N",
   q:"Quante intersezioni con l'asse x ha y=x²+2x+5?",
   opts:["0 (Δ<0)","1 (Δ=0)","2 (Δ>0)","Dipende da a"],
   ans:0,why:"Δ=4−20=−16<0: nessuna intersezione.",
   wr:["1: richiederebbe Δ=0.","2: richiederebbe Δ>0.","a=1>0 e Δ<0: caso determinato."]},
  {id:"p18",cat:"La Parabola",type:"N",
   q:"Valore di a per cui y=ax²−2x+1 è tangente all'asse x?",
   opts:["a=1","a=−1","a=2","a=0"],
   ans:0,why:"Δ=4−4a=0 → a=1.",
   wr:["a=−1: Δ=4+4=8>0.","a=2: Δ=4−8<0 (nessuna intersezione).","a=0: non è una parabola."]},
  {id:"p19",cat:"La Parabola",type:"N",
   q:"Somma delle radici di x²−5x+6=0 (per Vieta)?",
   opts:["5","6","−5","1"],
   ans:0,why:"x₁+x₂=−b/a=5. Verifica: (x−2)(x−3), 2+3=5.",
   wr:["6=x₁·x₂ (prodotto, non somma).","−5: manca il segno −b.","1=a, non la somma."]},
  {id:"p20",cat:"La Parabola",type:"N",
   q:"Prodotto delle radici di x²−5x+6=0 (per Vieta)?",
   opts:["6","5","−6","30"],
   ans:0,why:"x₁·x₂=c/a=6. Verifica: 2·3=6.",
   wr:["5=x₁+x₂ (somma).","−6: c=6>0.","30=5·6 errato."]},
  /* ── Le Coniche · 10 Teorici ────────────────────────── */
  {id:"cn1",cat:"Le Coniche",type:"T",
   q:"L'equazione della circonferenza con centro O(0,0) e raggio r è:",
   opts:["x²+y²=r²","x²+y²=r","x+y=r","x²−y²=r²"],
   ans:0,why:"d(P,O)=r → √(x²+y²)=r → x²+y²=r².",
   wr:["x²+y²=r: manca l'elevamento al quadrato di r.","x+y=r: non è la distanza.","x²−y²=r²: è un'iperbole, non una circonferenza."]},
  {id:"cn2",cat:"Le Coniche",type:"T",
   q:"Il centro della circonferenza (x−a)²+(y−b)²=r² è:",
   opts:["C(a,b)","C(−a,−b)","C(a,−b)","C(−a,b)"],
   ans:0,why:"Il centro è il punto (a,b) che azzera entrambi i quadrati.",
   wr:["C(−a,−b): segni sbagliati.","C(a,−b): y è b, non −b.","C(−a,b): x è a, non −a."]},
  {id:"cn3",cat:"Le Coniche",type:"T",
   q:"Per portare x²+y²+Dx+Ey+F=0 in forma canonica si usa:",
   opts:["Il completamento del quadrato","La formula quadratica","Il discriminante","La sostituzione t=x+y"],
   ans:0,why:"Si completa il quadrato in x e in y separatamente per ottenere (x−a)²+(y−b)²=r².",
   wr:["La formula quadratica risolve equazioni, non trasforma in forma canonica.","Il discriminante serve per il numero di zeri.","La sostituzione t=x+y non porta alla forma canonica."]},
  {id:"cn4",cat:"Le Coniche",type:"T",
   q:"L'ellisse x²/a²+y²/b²=1 con a>b>0 ha i fuochi su:",
   opts:["L'asse x","L'asse y","L'origine","Le bisettrici"],
   ans:0,why:"Con a>b: fuochi F(±c,0) sull'asse x, con c=√(a²−b²).",
   wr:["Asse y: solo se b>a.","L'origine: i fuochi sono simmetrici rispetto a O.","Le bisettrici non c'entrano."]},
  {id:"cn5",cat:"Le Coniche",type:"T",
   q:"Gli asintoti dell'iperbole x²/a²−y²/b²=1 sono:",
   opts:["y=±(b/a)x","y=±(a/b)x","y=±a","y=±b"],
   ans:0,why:"Gli asintoti dell'iperbole sono y=±(b/a)x.",
   wr:["y=±(a/b)x: a e b scambiati.","y=±a: costanti, non rette con pendenza.","y=±b: costanti."]},
  {id:"cn6",cat:"Le Coniche",type:"T",
   q:"L'asintoto verticale di y=(ax+b)/(cx+d) è:",
   opts:["x=−d/c","x=d/c","x=a/c","x=−b/a"],
   ans:0,why:"Il denominatore cx+d=0 → x=−d/c.",
   wr:["x=d/c: manca il segno −.","x=a/c: è l'asintoto orizzontale.","x=−b/a: annulla il numeratore."]},
  {id:"cn7",cat:"Le Coniche",type:"T",
   q:"L'asintoto orizzontale di y=(ax+b)/(cx+d) è:",
   opts:["y=a/c","y=b/d","y=d/c","y=a/b"],
   ans:0,why:"Per x→∞: y→ax/cx=a/c.",
   wr:["y=b/d: termini noti, non i coefficienti di x.","y=d/c: è legato all'asintoto verticale.","y=a/b: mescola coefficienti."]},
  {id:"cn8",cat:"Le Coniche",type:"T",
   q:"L'ellisse traslata con centro C(h,k) ha equazione:",
   opts:["(x−h)²/a²+(y−k)²/b²=1","x²/a²+y²/b²=1","(x+h)²/a²+(y+k)²/b²=1","(x−h)²/(a−h)²+(y−k)²/(b−k)²=1"],
   ans:0,why:"La traslazione sostituisce x→(x−h) e y→(y−k).",
   wr:["Ellisse centrata in O.","(x+h)²: porta a centro (−h,−k).","I semi-assi a e b non cambiano con la traslazione."]},
  {id:"cn9",cat:"Le Coniche",type:"T",
   q:"Una retta è tangente a una circonferenza se:",
   opts:["La distanza dal centro = raggio","La distanza dal centro < raggio","La distanza dal centro > raggio","Passa per il centro"],
   ans:0,why:"d(C,retta)=r: un solo punto di tangenza.",
   wr:["d<r: retta secante (2 intersezioni).","d>r: retta esterna (0 intersezioni).","La retta per il centro è una corda diametrale."]},
  {id:"cn10",cat:"Le Coniche",type:"T",
   q:"Per l'iperbole c²=a²+b² mentre per l'ellisse c²=:",
   opts:["a²−b²","a²+b²","b²−a²","a·b"],
   ans:0,why:"Per l'ellisse c²=a²−b² (con a>b>0), diverso dall'iperbole dove c²=a²+b².",
   wr:["a²+b²: vale per l'iperbole.","b²−a²: negativo se a>b, non valido.","a·b: non è la formula corretta."]},
  /* ── Le Coniche · 10 Numerici ───────────────────────── */
  {id:"cn11",cat:"Le Coniche",type:"N",
   q:"Raggio della circonferenza x²+y²=25?",
   opts:["5","25","√5","10"],
   ans:0,why:"r²=25 → r=5.",
   wr:["25=r², non r.","√5≈2.24: √25=5.","10=2r."]},
  {id:"cn12",cat:"Le Coniche",type:"N",
   q:"Centro e raggio di (x−3)²+(y+2)²=16?",
   opts:["C(3,−2), r=4","C(−3,2), r=4","C(3,−2), r=16","C(3,2), r=4"],
   ans:0,why:"Centro C(3,−2); r²=16→r=4.",
   wr:["C(−3,2): segni sbagliati.","r=16=r², non r.","y: (y+2)=(y−(−2)), quindi k=−2."]},
  {id:"cn13",cat:"Le Coniche",type:"N",
   q:"Semi-asse maggiore di x²/25+y²/9=1?",
   opts:["5","3","√25","9"],
   ans:0,why:"a²=25→a=5 (denominatore maggiore, asse x).",
   wr:["3=b (semi-asse minore).","√25=5: corretto ma opzione ambigua; la risposta è 5.","9=b²."]},
  {id:"cn14",cat:"Le Coniche",type:"N",
   q:"Asintoti dell'iperbole x²/4−y²/9=1?",
   opts:["y=±(3/2)x","y=±(2/3)x","y=±3x","y=±2x"],
   ans:0,why:"a=2, b=3 → y=±(b/a)x=±(3/2)x.",
   wr:["y=±(2/3)x: a e b scambiati.","y=±3x: solo b.","y=±2x: solo a."]},
  {id:"cn15",cat:"Le Coniche",type:"N",
   q:"Asintoto verticale di y=(2x+1)/(x−3)?",
   opts:["x=3","x=−3","x=2","x=1/2"],
   ans:0,why:"x−3=0 → x=3.",
   wr:["x=−3: segno sbagliato.","x=2: coefficiente di x al numeratore.","x=1/2: annulla il numeratore, non il denominatore."]},
  {id:"cn16",cat:"Le Coniche",type:"N",
   q:"Asintoto orizzontale di y=(2x+1)/(x−3)?",
   opts:["y=2","y=1","y=−1/3","y=3"],
   ans:0,why:"y=a/c=2/1=2.",
   wr:["y=1: termine noto del numeratore.","y=−1/3: valore in x=0.","y=3: asintoto verticale."]},
  {id:"cn17",cat:"Le Coniche",type:"N",
   q:"Centro della circonferenza x²+y²−6x+4y−3=0?",
   opts:["C(3,−2)","C(−3,2)","C(6,−4)","C(3,2)"],
   ans:0,why:"Completamento: (x−3)²+(y+2)²=16. Centro C(3,−2).",
   wr:["C(−3,2): segni sbagliati.","C(6,−4): sono D e E, non il centro.","y: (y+2)²→k=−2."]},
  {id:"cn18",cat:"Le Coniche",type:"N",
   q:"Raggio della circonferenza x²+y²−6x+4y−3=0?",
   opts:["4","16","3","√3"],
   ans:0,why:"r²=9+4+3=16 → r=4.",
   wr:["16=r².","3=√(D/2)² sbagliato.","√3: r=4, non √3."]},
  {id:"cn19",cat:"Le Coniche",type:"N",
   q:"Centro dell'ellisse (x−2)²/16+(y+1)²/9=1?",
   opts:["C(2,−1)","C(−2,1)","C(2,1)","C(4,3)"],
   ans:0,why:"h=2, k=−1 → C(2,−1).",
   wr:["Segni sbagliati.","k=−1, non 1.","4=a, 3=b: semi-assi, non centro."]},
  {id:"cn20",cat:"Le Coniche",type:"N",
   q:"Centro dell'iperbole (x+1)²/9−(y−2)²/4=1?",
   opts:["C(−1,2)","C(1,−2)","C(3,2)","C(−1,−2)"],
   ans:0,why:"(x+1)²=(x−(−1))²→h=−1; (y−2)²→k=2. C(−1,2).",
   wr:["C(1,−2): segni sbagliati.","C(3,2): 3=a, non h.","C(−1,−2): k=2, non −2."]},
];

/* ── MAIN COMPONENT ──────────────────────────────────── */

/* ── ERROR BOUNDARY ──────────────────────────────────── */
class EB extends Component{
  constructor(p){super(p);this.state={err:null};}
  static getDerivedStateFromError(e){return{err:e};}
  render(){
    if(this.state.err)return(
      <div style={{minHeight:"100vh",display:"flex",flexDirection:"column",alignItems:"center",
        justifyContent:"center",fontFamily:"system-ui,sans-serif",padding:24,textAlign:"center",
        background:"#f0f4f8"}}>
        <div style={{fontSize:64,marginBottom:16}}>⚠️</div>
        <h2 style={{color:"#dc2626",marginBottom:8,fontSize:22}}>Qualcosa è andato storto</h2>
        <p style={{color:"#6b7280",marginBottom:4,maxWidth:400,lineHeight:1.6}}>{this.state.err.message}</p>
        <p style={{color:"#9ca3af",fontSize:13,marginBottom:24}}>
          I tuoi progressi sono salvati. Ricarica per riprendere.
        </p>
        <button onClick={()=>window.location.reload()}
          style={{background:"#2563eb",color:"white",border:"none",borderRadius:10,
            padding:"12px 28px",cursor:"pointer",fontSize:15,fontWeight:600}}>
          🔄 Ricarica la pagina
        </button>
      </div>
    );
    return this.props.children;
  }
}

/* ── APP ─────────────────────────────────────────────── */
function AppInner(){
  const [done,setDone]=useState(()=>{
    try{const s=localStorage.getItem('pc_done');return s?new Set(JSON.parse(s)):new Set();}
    catch{return new Set();}
  });
  const [qAnswers,setQAnswers]=useState(()=>{
    try{return JSON.parse(localStorage.getItem('pc_qa')||'{}');}
    catch{return {};}
  });
  useEffect(()=>{try{localStorage.setItem('pc_done',JSON.stringify([...done]));}catch{}},[done]);
  useEffect(()=>{try{localStorage.setItem('pc_qa',JSON.stringify(qAnswers));}catch{}},[qAnswers]);

  const [view,setView]=useState("list");
  const [navSection,setNavSection]=useState("home");
  const [selId,setSelId]=useState(null);
  const [step,setStep]=useState(0);
  const [hint,setHint]=useState(false);
  const [phase,setPhase]=useState("enunciato");
  const [selQid,setSelQid]=useState(null);
  const [qSection,setQSection]=useState(null);

  const card=CARDS.find(c=>c.id===selId);
  const quiz=QUIZZES.find(q=>q.id===selQid);
  const sectionCards=navSection==="home"||navSection==="quiz"?CARDS:CARDS.filter(c=>c.cat===navSection);
  const pct=Math.round(done.size/CARDS.length*100);
  const qCorrect=QUIZZES.filter(q=>qAnswers[q.id]===q.ans).length;

  const openCard=(id)=>{setSelId(id);setStep(0);setHint(false);setPhase("enunciato");setView("detail");};
  const goNav=(sec)=>{setQSection(null);setNavSection(sec);setView("list");};
  const openSectionQuiz=(cat)=>{setQSection(cat);setNavSection("quiz");setView("list");};
  const next=()=>{
    if(!card)return;
    if(phase==="enunciato"){setPhase("steps");setStep(0);setHint(false);return;}
    if(step<card.steps.length-1){setStep(s=>s+1);setHint(false);}
    else{setPhase("done");setDone(p=>new Set([...p,card.id]));}
  };
  const prev=()=>{
    if(phase==="steps"&&step>0){setStep(s=>s-1);setHint(false);}
    else if(phase==="steps"&&step===0){setPhase("enunciato");setHint(false);}
    else if(phase==="done"){setPhase("steps");setStep(card.steps.length-1);setHint(false);}
  };
  const answer=(qid,idx)=>{if(qAnswers[qid]===undefined)setQAnswers(p=>({...p,[qid]:idx}));};
  const FigComp=card?FIGS[card.id]:null;

  const ALL_CATS=["Piano Cartesiano","La Retta","La Parabola","Le Coniche"];
  const CAT_SHORT={"Piano Cartesiano":"PIANO CART.","La Retta":"LA RETTA","La Parabola":"LA PARABOLA","Le Coniche":"LE CONICHE"};
  const NAV=[
    {key:"home",   label:"Home",          icon:"🏠"},
    {key:"Piano Cartesiano", label:"Piano Cart.", icon:"📍"},
    {key:"La Retta",         label:"La Retta",   icon:"📏"},
    {key:"La Parabola",      label:"La Parabola",icon:"⤴️"},
    {key:"Le Coniche",       label:"Le Coniche", icon:"⭕"},
    {key:"quiz",   label:"Quiz",          icon:"🧠"},
  ];
  const SEC_DESC={
    "Piano Cartesiano":"Distanza tra punti, punto medio, perimetro e riconoscimento di figure.",
    "La Retta":"Equazioni, pendenza, rette parallele e perpendicolari, distanza punto-retta.",
    "La Parabola":"Vertice, asse di simmetria, intersezioni, tangenza e parabola per tre punti.",
    "Le Coniche":"Circonferenza, ellisse, iperbole e funzione omografica con assi paralleli agli assi cartesiani.",
  };

  const isNavActive=(key)=>navSection===key&&view==="list";
  const BASE_STYLE=`*{box-sizing:border-box}body{margin:0}
    .btn-nav{border:none;background:transparent;cursor:pointer;transition:all .15s;font-family:system-ui,sans-serif}
    .btn-nav:hover{background:rgba(255,255,255,.18)!important}
    .card-hover{transition:all .2s;cursor:pointer;border:none;background:none;width:100%;text-align:left}
    .card-hover:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,0,0,.12)!important}
    .opt-btn{cursor:pointer;transition:all .2s;text-align:left;font-family:system-ui,sans-serif}
    .opt-btn:hover:not(:disabled){filter:brightness(.96)}
    .action-btn{cursor:pointer;border:none;font-family:system-ui,sans-serif;font-weight:600;transition:all .15s}
    .action-btn:hover{filter:brightness(1.07);transform:translateY(-1px)}
    .hint-btn{cursor:pointer;border:none;background:#fef9c3;border-radius:8px;padding:7px 14px;font-family:system-ui,sans-serif;font-size:13px;color:#854d0e;transition:background .15s}
    .hint-btn:hover{background:#fef08a}`;

  /* ── HEADER ─────────────────────────────────────────── */
  const Header=({back,backLabel,title,subtitle})=>(
    <div style={{background:"#2563eb",color:"white"}}>
      <div style={{padding:"14px 16px 0",maxWidth:960,margin:"0 auto",display:"flex",alignItems:"center",gap:10}}>
        {back&&<button onClick={back} style={{border:"none",background:"rgba(255,255,255,.15)",color:"white",borderRadius:8,padding:"6px 12px",cursor:"pointer",fontFamily:"system-ui,sans-serif",fontSize:13,display:"flex",alignItems:"center",gap:5}}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round"><polyline points="15,18 9,12 15,6"/></svg>{backLabel}
        </button>}
        <div style={{flex:1}}>
          <h1 style={{margin:0,fontSize:back?"16px":"clamp(17px,3.5vw,24px)",fontWeight:700,fontFamily:"system-ui,sans-serif",lineHeight:1.2}}>
            {title||"📐 Piano Cartesiano"}
          </h1>
          {subtitle&&<p style={{margin:"2px 0 0",fontSize:12,opacity:.8,fontFamily:"system-ui,sans-serif"}}>{subtitle}</p>}
          {!back&&<p style={{margin:"2px 0 0",fontSize:12,opacity:.8,fontFamily:"system-ui,sans-serif"}}>Geometria analitica · schede, figure & quiz</p>}
        </div>
        {!back&&<div style={{textAlign:"right",fontSize:12,opacity:.9,lineHeight:1.7}}>
          <div>📚 {done.size}/{CARDS.length}</div>
          <div>🧠 {qCorrect}/{QUIZZES.length}</div>
        </div>}
      </div>
      <nav style={{maxWidth:960,margin:"0 auto",padding:"10px 12px 0",display:"flex",gap:2,overflowX:"auto",scrollbarWidth:"none"}}>
        {NAV.map(({key,label,icon})=>(
          <button key={key} className="btn-nav" onClick={()=>goNav(key)}
            style={{background:isNavActive(key)?"rgba(255,255,255,.2)":"transparent",
              color:"white",padding:"7px 13px",borderRadius:"8px 8px 0 0",whiteSpace:"nowrap",
              fontSize:13,fontWeight:isNavActive(key)?700:400,
              borderBottom:isNavActive(key)?"3px solid white":"3px solid transparent"}}>
            {icon} {label}
          </button>
        ))}
      </nav>
    </div>
  );

  /* ── QUIZ DETAIL ─────────────────────────────────────── */
  if(view==="quiz"&&quiz){
    const cc=CC[quiz.cat];
    const chosen=qAnswers[quiz.id];
    const answered=chosen!==undefined;
    const correct=chosen===quiz.ans;
    const qList=qSection?QUIZZES.filter(q=>q.cat===qSection):
      navSection==="quiz"||navSection==="home"?QUIZZES:QUIZZES.filter(q=>q.cat===quiz.cat);
    const qIdx=qList.findIndex(q=>q.id===quiz.id);
    const nextQ=qList[qIdx+1];
    const prevQ=qList[qIdx-1];
    return(
      <div style={{minHeight:"100vh",background:"#f0f4f8",fontFamily:"system-ui,sans-serif"}}>
        <style>{BASE_STYLE}</style>
        <Header back={()=>{setNavSection("quiz");setView("list");}} backLabel="Quiz"
          title={`${quiz.cat} · ${quiz.type==="T"?"Teorico":"Numerico"}`}
          subtitle={`Domanda ${qIdx+1} di ${qList.length}`}/>
        <div style={{maxWidth:680,margin:"0 auto",padding:"20px 14px 80px"}}>
          <div style={{display:"flex",gap:3,marginBottom:18,flexWrap:"wrap"}}>
            {qList.map((q,i)=>{
              const a=qAnswers[q.id];
              return <div key={q.id} title={`Dom. ${i+1}`}
                style={{width:10,height:10,borderRadius:"50%",
                  background:q.id===quiz.id?"#2563eb":a===undefined?"#cbd5e1":a===q.ans?"#16a34a":"#dc2626",
                  border:q.id===quiz.id?"2px solid #1d4ed8":"none",transition:"all .3s"}}/>;
            })}
          </div>
          <div style={{background:"white",borderRadius:12,padding:"20px",marginBottom:14,
            borderLeft:`4px solid ${cc.acc}`,boxShadow:"0 1px 6px rgba(0,0,0,.07)"}}>
            <div style={{display:"flex",gap:8,marginBottom:12,alignItems:"center"}}>
              <span style={{background:quiz.type==="T"?"#dbeafe":"#dcfce7",color:quiz.type==="T"?"#1d4ed8":"#15803d",
                fontSize:11,fontWeight:700,padding:"3px 10px",borderRadius:20,letterSpacing:.5}}>
                {quiz.type==="T"?"TEORICO":"NUMERICO"}
              </span>
              <span style={{fontSize:12,color:"#6b7280"}}>{cc.icon} {quiz.cat}</span>
            </div>
            <p style={{margin:0,fontSize:16,lineHeight:1.7,color:"#1f2937",fontWeight:500}}>{quiz.q}</p>
          </div>
          <div style={{display:"flex",flexDirection:"column",gap:8,marginBottom:14}}>
            {quiz.opts.map((opt,i)=>{
              const isChosen=chosen===i,isCorrect=i===quiz.ans;
              let bg="white",brd="#e5e7eb",clr="#374151",lclr="#6b7280";
              if(answered){
                if(isCorrect){bg="#f0fdf4";brd="#86efac";clr="#15803d";lclr="#15803d";}
                else if(isChosen){bg="#fef2f2";brd="#fca5a5";clr="#b91c1c";lclr="#b91c1c";}
              }
              return(
                <button key={i} className="opt-btn" disabled={answered} onClick={()=>answer(quiz.id,i)}
                  style={{background:bg,border:`2px solid ${brd}`,borderRadius:10,padding:"12px 16px",
                    color:clr,fontSize:14,lineHeight:1.5,display:"flex",alignItems:"flex-start",gap:10}}>
                  <span style={{fontWeight:700,minWidth:22,color:lclr}}>{["A","B","C","D"][i]}.</span>
                  <span style={{flex:1}}>{opt}</span>
                  {answered&&isCorrect&&<span>✅</span>}
                  {answered&&isChosen&&!isCorrect&&<span>❌</span>}
                </button>
              );
            })}
          </div>
          {answered?(
            <div style={{background:correct?"#f0fdf4":"#fff7ed",border:`1px solid ${correct?"#86efac":"#fed7aa"}`,
              borderRadius:10,padding:"14px 16px",marginBottom:14}}>
              <div style={{fontWeight:700,fontSize:14,marginBottom:8,color:correct?"#15803d":"#c2410c"}}>
                {correct?"✅ Risposta corretta!":"❌ Risposta errata"}
              </div>
              {!correct&&<p style={{margin:"0 0 8px",fontSize:13,color:"#b91c1c",lineHeight:1.6}}>
                <strong>Errore:</strong> {quiz.wr[chosen]}
              </p>}
              <p style={{margin:0,fontSize:13,color:"#1f2937",lineHeight:1.6}}>
                <strong>Risposta corretta ({["A","B","C","D"][quiz.ans]}):</strong> {quiz.why}
              </p>
            </div>
          ):(
            <p style={{textAlign:"center",color:"#9ca3af",fontSize:13,fontStyle:"italic",marginBottom:14}}>
              Seleziona una risposta per vedere il feedback immediato
            </p>
          )}
          <div style={{display:"flex",gap:8}}>
            {prevQ&&<button className="action-btn" onClick={()=>setSelQid(prevQ.id)}
              style={{flex:1,background:"#f3f4f6",color:"#374151",borderRadius:10,padding:"12px",fontSize:14}}>← Precedente</button>}
            {nextQ?<button className="action-btn" onClick={()=>setSelQid(nextQ.id)} disabled={!answered}
              style={{flex:2,background:answered?"#2563eb":"#e5e7eb",color:answered?"white":"#9ca3af",
                borderRadius:10,padding:"12px",fontSize:14,cursor:answered?"pointer":"default"}}>Prossima →</button>
            :<button className="action-btn" onClick={()=>{setNavSection("quiz");setView("list");}}
              style={{flex:2,background:"#2563eb",color:"white",borderRadius:10,padding:"12px",fontSize:14}}>🏠 Torna ai quiz</button>}
          </div>
        </div>
      </div>
    );
  }

  /* ── LIST VIEW ───────────────────────────────────────── */
  if(view==="list"){
    const catDone=(cat)=>CARDS.filter(c=>c.cat===cat&&done.has(c.id)).length;
    const catTotal=(cat)=>CARDS.filter(c=>c.cat===cat).length;
    const qCatCorrect=(cat)=>QUIZZES.filter(q=>q.cat===cat&&qAnswers[q.id]===q.ans).length;
    const qCatTotal=(cat)=>QUIZZES.filter(q=>q.cat===cat).length;
    const quizCats=qSection?[qSection]:ALL_CATS;

    return(
      <div style={{minHeight:"100vh",background:"#f0f4f8",fontFamily:"system-ui,sans-serif"}}>
        <style>{BASE_STYLE}</style>
        <Header/>
        <div style={{maxWidth:960,margin:"0 auto",padding:"20px 14px 40px"}}>

          {/* HOME */}
          {navSection==="home"&&(<>
            <div style={{background:"white",borderRadius:12,padding:"20px 24px",marginBottom:20,
              boxShadow:"0 1px 4px rgba(0,0,0,.07)"}}>
              <h2 style={{margin:"0 0 10px",fontSize:18,color:"#1f2937"}}>Cos'è questa app?</h2>
              <p style={{margin:"0 0 8px",fontSize:14,color:"#374151",lineHeight:1.7}}>
                Studia la <strong>geometria analitica</strong> con schede interattive passo-passo,
                figure SVG animate e quiz a risposta multipla con feedback immediato.
                Ogni sezione contiene schede guidate e <strong>20 quiz</strong> (10 teorici + 10 numerici).
              </p>
              <div style={{background:"#f0fdf4",border:"1px solid #bbf7d0",borderRadius:8,padding:"10px 14px",fontSize:13,color:"#15803d"}}>
                💡 <strong>Suggerimento:</strong> studia la scheda, segui i passi guidati, poi mettiti alla prova con i quiz.
                I tuoi progressi vengono salvati anche dopo aver chiuso la pagina.
              </div>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:12,marginBottom:24}}>
              {ALL_CATS.map(cat=>{
                const cc=CC[cat];
                const nd=catDone(cat),nt=catTotal(cat);
                return(
                  <button key={cat} className="card-hover" onClick={()=>goNav(cat)}
                    style={{background:"white",border:`1.5px solid #e5e7eb`,borderRadius:12,padding:"18px 16px",
                      textAlign:"left",boxShadow:"0 1px 4px rgba(0,0,0,.06)",borderLeft:`4px solid ${cc.acc}`}}>
                    <div style={{fontSize:28,marginBottom:8}}>{cc.icon}</div>
                    <div style={{fontSize:15,fontWeight:700,color:cc.acc,marginBottom:4}}>{cat}</div>
                    <div style={{fontSize:12,color:"#6b7280",lineHeight:1.5,marginBottom:10}}>{SEC_DESC[cat]}</div>
                    <div style={{fontSize:11,color:"#9ca3af",marginBottom:4}}>{nd}/{nt} schede · {qCatCorrect(cat)}/{qCatTotal(cat)} quiz</div>
                    <div style={{height:4,background:"#e5e7eb",borderRadius:2,overflow:"hidden"}}>
                      <div style={{height:"100%",background:cc.acc,width:`${nt?Math.round(nd/nt*100):0}%`,transition:"width .4s"}}/>
                    </div>
                  </button>
                );
              })}
              <button className="card-hover" onClick={()=>goNav("quiz")}
                style={{background:"white",border:"1.5px solid #e5e7eb",borderRadius:12,padding:"18px 16px",
                  textAlign:"left",boxShadow:"0 1px 4px rgba(0,0,0,.06)",borderLeft:"4px solid #16a34a"}}>
                <div style={{fontSize:28,marginBottom:8}}>🧠</div>
                <div style={{fontSize:15,fontWeight:700,color:"#16a34a",marginBottom:4}}>Quiz</div>
                <div style={{fontSize:12,color:"#6b7280",lineHeight:1.5,marginBottom:10}}>
                  80 domande totali — 20 per sezione, mix teorico e numerico.
                </div>
                <div style={{fontSize:11,color:"#9ca3af",marginBottom:4}}>{qCorrect}/{QUIZZES.length} corrette</div>
                <div style={{height:4,background:"#e5e7eb",borderRadius:2,overflow:"hidden"}}>
                  <div style={{height:"100%",background:"#16a34a",width:`${Math.round(qCorrect/QUIZZES.length*100)}%`,transition:"width .4s"}}/>
                </div>
              </button>
            </div>
            <h3 style={{margin:"0 0 10px",fontSize:16,color:"#374151"}}>📊 I tuoi progressi</h3>
            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(140px,1fr))",gap:8}}>
              {ALL_CATS.map(cat=>{
                const cc=CC[cat],nd=catDone(cat),nt=catTotal(cat);
                const qc=qCatCorrect(cat),qt=qCatTotal(cat);
                return(
                  <div key={cat} style={{background:"white",borderRadius:10,padding:"12px",
                    boxShadow:"0 1px 3px rgba(0,0,0,.06)",borderTop:`3px solid ${cc.acc}`}}>
                    <div style={{fontSize:10,color:"#9ca3af",textTransform:"uppercase",letterSpacing:.5,marginBottom:4}}>
                      {CAT_SHORT[cat]}
                    </div>
                    <div style={{fontSize:13,fontWeight:600,color:nd>0?"#1f2937":"#9ca3af",marginBottom:2}}>
                      {nd===0?"Non svolto":`${nd}/${nt} schede`}
                    </div>
                    <div style={{fontSize:12,color:qc>0?"#16a34a":"#9ca3af"}}>{qc}/{qt} quiz</div>
                  </div>
                );
              })}
              <div style={{background:"white",borderRadius:10,padding:"12px",
                boxShadow:"0 1px 3px rgba(0,0,0,.06)",borderTop:"3px solid #16a34a"}}>
                <div style={{fontSize:10,color:"#9ca3af",textTransform:"uppercase",letterSpacing:.5,marginBottom:4}}>QUIZ TOT.</div>
                <div style={{fontSize:13,fontWeight:600,color:qCorrect>0?"#1f2937":"#9ca3af",marginBottom:2}}>
                  {qCorrect===0?"Non svolto":`${qCorrect}/${QUIZZES.length}`}
                </div>
                <div style={{fontSize:12,color:"#6b7280"}}>{Math.round(qCorrect/QUIZZES.length*100)}% corretto</div>
              </div>
            </div>
          </>)}

          {/* SECTION SCHEDE */}
          {navSection!=="home"&&navSection!=="quiz"&&(<>
            <div style={{background:"white",borderRadius:12,padding:"14px 18px",marginBottom:16,
              borderLeft:`4px solid ${CC[navSection].acc}`,boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
              <p style={{margin:"0 0 8px",fontSize:14,color:"#374151"}}>{SEC_DESC[navSection]}</p>
              <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:8}}>
                <div style={{fontSize:12,color:"#6b7280"}}>
                  {catDone(navSection)}/{catTotal(navSection)} schede completate &nbsp;·&nbsp;
                  {qCatCorrect(navSection)}/{qCatTotal(navSection)} quiz corretti
                </div>
                <button className="action-btn" onClick={()=>openSectionQuiz(navSection)}
                  style={{background:CC[navSection].acc,color:"white",borderRadius:8,padding:"6px 14px",fontSize:12}}>
                  🧠 Quiz di questa sezione →
                </button>
              </div>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(260px,1fr))",gap:10}}>
              {sectionCards.map(c=>{
                const cc=CC[c.cat],isDone=done.has(c.id);
                return(
                  <button key={c.id} className="card-hover" onClick={()=>openCard(c.id)}
                    style={{background:"white",border:`1.5px solid ${isDone?"#fbbf24":"#e5e7eb"}`,borderRadius:12,
                      padding:"14px 16px",position:"relative",boxShadow:isDone?"0 0 0 3px rgba(251,191,36,.2)":"0 1px 4px rgba(0,0,0,.05)",
                      borderLeft:`4px solid ${cc.acc}`}}>
                    {isDone&&<span style={{position:"absolute",top:10,right:12,fontSize:14}}>✅</span>}
                    <div style={{fontSize:11,color:"#9ca3af",marginBottom:3}}>Scheda {c.id}</div>
                    <div style={{fontSize:14,fontWeight:700,color:"#1f2937",lineHeight:1.4,marginBottom:6}}>{c.title}</div>
                    <div style={{fontSize:11,color:DC[c.diff]}}>{DL[c.diff]}</div>
                  </button>
                );
              })}
            </div>
          </>)}

          {/* QUIZ LIST */}
          {navSection==="quiz"&&(<>
            <div style={{background:"white",borderRadius:12,padding:"14px 18px",marginBottom:16,
              borderLeft:"4px solid #16a34a",boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
              <p style={{margin:"0 0 6px",fontSize:14,color:"#374151"}}>
                {qSection?`Quiz di: ${qSection}`:"80 domande totali — 20 per sezione (10 teorici + 10 numerici)."}
              </p>
              <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:8}}>
                <div style={{fontSize:12,color:"#6b7280"}}>{qCorrect}/{QUIZZES.length} corrette · {Object.keys(qAnswers).length} tentate</div>
                {qSection&&<button onClick={()=>setQSection(null)}
                  style={{fontSize:11,color:"#6b7280",background:"#f3f4f6",border:"none",borderRadius:6,
                    padding:"4px 10px",cursor:"pointer"}}>
                  ✕ Tutte le sezioni
                </button>}
              </div>
            </div>
            {quizCats.map(cat=>{
              const cc=CC[cat];
              const catQ=QUIZZES.filter(q=>q.cat===cat);
              return(
                <div key={cat} style={{marginBottom:20}}>
                  <h3 style={{margin:"0 0 10px",fontSize:14,color:cc.acc,display:"flex",alignItems:"center",gap:6}}>
                    {cc.icon} {cat}
                    <span style={{fontSize:12,color:"#9ca3af",fontWeight:400}}>
                      — {qCatCorrect(cat)}/{qCatTotal(cat)} corrette
                    </span>
                  </h3>
                  <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(260px,1fr))",gap:8}}>
                    {catQ.map(q=>{
                      const chosen=qAnswers[q.id],answered=chosen!==undefined,correct=chosen===q.ans;
                      return(
                        <button key={q.id} className="card-hover" onClick={()=>{setSelQid(q.id);setView("quiz");}}
                          style={{background:answered?(correct?"#f0fdf4":"#fff7ed"):"white",
                            border:`1.5px solid ${answered?(correct?"#86efac":"#fed7aa"):"#e5e7eb"}`,
                            borderRadius:10,padding:"12px 14px",position:"relative",textAlign:"left",
                            boxShadow:"0 1px 3px rgba(0,0,0,.05)",borderLeft:`3px solid ${cc.acc}`}}>
                          {answered&&<span style={{position:"absolute",top:8,right:10,fontSize:13}}>{correct?"✅":"❌"}</span>}
                          <span style={{background:q.type==="T"?"#dbeafe":"#dcfce7",color:q.type==="T"?"#1d4ed8":"#15803d",
                            fontSize:10,fontWeight:700,padding:"2px 7px",borderRadius:20,letterSpacing:.5,marginBottom:6,display:"inline-block"}}>
                            {q.type==="T"?"TEORICO":"NUMERICO"}
                          </span>
                          <p style={{margin:"6px 0 0",fontSize:13,color:"#374151",lineHeight:1.45}}>
                            {q.q.length>80?q.q.slice(0,80)+"…":q.q}
                          </p>
                        </button>
                      );
                    })}
                  </div>
                </div>
              );
            })}
          </>)}
        </div>
      </div>
    );
  }

  /* ── CARD DETAIL VIEW ────────────────────────────────── */
  if(!card)return null;
  const cc=CC[card.cat];
  const totalP=card.steps.length+2;
  const progV=phase==="enunciato"?1:phase==="done"?totalP:step+2;
  const cur=card.steps[step];
  const pending=QUIZZES.filter(q=>q.cat===card.cat&&qAnswers[q.id]!==q.ans);
  const allQuizDone=pending.length===0;
  return(
    <div style={{minHeight:"100vh",background:"#f0f4f8",fontFamily:"system-ui,sans-serif"}}>
      <style>{BASE_STYLE}</style>
      <Header back={()=>{setNavSection(card.cat);setView("list");}} backLabel={card.cat}
        title={card.title} subtitle={`Scheda ${card.id} · ${DL[card.diff]}`}/>
      <div style={{height:4,background:"#dbeafe"}}>
        <div style={{height:"100%",background:cc.acc,width:`${(progV/totalP)*100}%`,transition:"width .4s ease"}}/>
      </div>
      <div style={{maxWidth:640,margin:"0 auto",padding:"16px 14px 80px"}}>
        {phase==="enunciato"&&(
          <div>
            {FigComp&&<div style={{background:"white",border:`1.5px solid #e5e7eb`,borderRadius:12,padding:"12px",
              marginBottom:12,height:200,display:"flex",alignItems:"center",justifyContent:"center",
              boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
              <FigComp step={-1} phase="enunciato"/>
            </div>}
            <div style={{background:"white",borderLeft:`4px solid ${cc.acc}`,borderRadius:12,padding:"18px",marginBottom:10,boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
              <div style={{fontSize:11,color:cc.acc,textTransform:"uppercase",letterSpacing:1.5,marginBottom:8,fontWeight:700}}>Enunciato</div>
              <p style={{margin:0,fontSize:15,lineHeight:1.75,color:"#1f2937",fontStyle:"italic"}}>{card.stmt}</p>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:10}}>
              <div style={{background:"white",border:"1.5px solid #e5e7eb",borderRadius:10,padding:"13px",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
                <div style={{fontSize:10,color:"#6b7280",marginBottom:5,textTransform:"uppercase",letterSpacing:1.5,fontWeight:600}}>Dati / Ipotesi</div>
                <p style={{margin:0,fontSize:12,lineHeight:1.6,color:"#374151"}}>{card.hyp}</p>
              </div>
              <div style={{background:"white",border:"1.5px solid #e5e7eb",borderRadius:10,padding:"13px",boxShadow:"0 1px 3px rgba(0,0,0,.05)"}}>
                <div style={{fontSize:10,color:"#6b7280",marginBottom:5,textTransform:"uppercase",letterSpacing:1.5,fontWeight:600}}>Obiettivo / Tesi</div>
                <p style={{margin:0,fontSize:12,lineHeight:1.6,color:"#374151",fontWeight:600}}>{card.tesi}</p>
              </div>
            </div>
            <div style={{background:"#fefce8",border:"1px solid #fde68a",borderRadius:10,padding:"12px 15px",marginBottom:16}}>
              <p style={{margin:0,fontSize:13,color:"#854d0e",lineHeight:1.6}}>{card.idea}</p>
            </div>
            <button className="action-btn" onClick={next}
              style={{width:"100%",background:cc.acc,color:"white",borderRadius:10,padding:"14px",fontSize:15}}>
              Inizia il procedimento →
            </button>
          </div>
        )}
        {phase==="steps"&&cur&&(
          <div>
            {FigComp&&<div style={{background:"white",border:"1.5px solid #e5e7eb",borderRadius:12,padding:"10px",
              marginBottom:12,height:200,display:"flex",alignItems:"center",justifyContent:"center",
              boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
              <FigComp step={step} phase="steps"/>
            </div>}
            <div style={{display:"flex",alignItems:"center",gap:5,marginBottom:14}}>
              {card.steps.map((_,i)=><div key={i} style={{height:5,flex:1,borderRadius:3,
                background:i<=step?cc.acc:"#e5e7eb",opacity:i<step?.5:1,transition:"all .3s"}}/>)}
              <span style={{fontSize:12,color:"#9ca3af",whiteSpace:"nowrap",marginLeft:4}}>{step+1}/{card.steps.length}</span>
            </div>
            <div style={{background:"white",border:"1.5px solid #e5e7eb",borderRadius:12,padding:"20px 18px",
              marginBottom:10,boxShadow:"0 2px 10px rgba(0,0,0,.06)"}}>
              <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:12}}>
                <div style={{width:30,height:30,borderRadius:"50%",background:cc.acc,color:"white",
                  display:"flex",alignItems:"center",justifyContent:"center",fontWeight:700,fontSize:14,flexShrink:0}}>{step+1}</div>
                <h3 style={{margin:0,fontSize:16,color:"#1f2937",fontWeight:700,lineHeight:1.3}}>{cur.ti}</h3>
              </div>
              <p style={{margin:0,fontSize:14,lineHeight:1.8,color:"#374151"}}>{cur.tx}</p>
            </div>
            <div style={{marginBottom:14}}>
              <button className="hint-btn" onClick={()=>setHint(h=>!h)}>
                💡 {hint?"Nascondi":"Mostra"} suggerimento
              </button>
              {hint&&<div style={{background:"#fefce8",border:"1px solid #fde68a",borderRadius:8,padding:"10px 14px",marginTop:7}}>
                <p style={{margin:0,fontSize:13,color:"#854d0e",lineHeight:1.65}}>{cur.hi}</p>
              </div>}
            </div>
            <div style={{display:"flex",gap:8}}>
              <button className="action-btn" onClick={prev}
                style={{flex:1,background:"#f3f4f6",color:"#374151",borderRadius:10,padding:"12px",fontSize:14}}>← Indietro</button>
              <button className="action-btn" onClick={next}
                style={{flex:2,background:cc.acc,color:"white",borderRadius:10,padding:"12px",fontSize:14}}>
                {step<card.steps.length-1?"Passo successivo →":"Concludi ✓"}
              </button>
            </div>
          </div>
        )}
        {phase==="done"&&(
          <div style={{paddingTop:36,textAlign:"center"}}>
            <div style={{fontSize:60,marginBottom:14}}>🎉</div>
            <h2 style={{fontSize:24,color:"#1f2937",marginBottom:6}}>Scheda completata!</h2>
            <p style={{fontSize:15,color:cc.acc,fontWeight:600,marginBottom:20}}>{card.title}</p>
            <div style={{background:"white",border:`1.5px solid #e5e7eb`,borderLeft:`4px solid ${cc.acc}`,
              borderRadius:12,padding:"14px 18px",marginBottom:16,textAlign:"left",boxShadow:"0 1px 4px rgba(0,0,0,.06)"}}>
              <div style={{fontSize:10,color:cc.acc,marginBottom:6,textTransform:"uppercase",letterSpacing:1.5,fontWeight:700}}>Risultato:</div>
              <p style={{margin:0,fontSize:14,fontStyle:"italic",color:"#1f2937",lineHeight:1.7}}>{card.tesi}</p>
            </div>
            <div style={{background:"#f0fdf4",border:"1px solid #bbf7d0",borderRadius:10,padding:"12px 16px",marginBottom:16}}>
              <p style={{margin:0,fontSize:14,color:"#15803d"}}>✅ Schede completate: <strong>{done.size}</strong> / {CARDS.length} ({pct}%)</p>
            </div>
            {allQuizDone?(
              <div style={{background:"#f0fdf4",border:"1px solid #bbf7d0",borderRadius:10,padding:"12px 16px",marginBottom:16}}>
                <p style={{margin:0,fontSize:13,color:"#15803d",fontWeight:600}}>🏆 Ottimo! Hai risposto correttamente a tutti i quiz di {card.cat}.</p>
              </div>
            ):(
              <div style={{background:"#fefce8",border:"1px solid #fde68a",borderRadius:10,padding:"14px 16px",marginBottom:16,textAlign:"left"}}>
                <p style={{margin:"0 0 10px",fontSize:13,color:"#854d0e",fontWeight:600}}>
                  🧠 Quiz di {card.cat} ancora aperti ({pending.length}):
                </p>
                <div style={{display:"flex",flexDirection:"column",gap:6}}>
                  {pending.slice(0,4).map(q=>{
                    const isWrong=qAnswers[q.id]!==undefined;
                    return(
                      <button key={q.id}
                        onClick={()=>{setQSection(card.cat);setNavSection("quiz");setSelQid(q.id);setView("quiz");}}
                        style={{background:"white",border:"1px solid #fde68a",borderRadius:8,padding:"8px 12px",
                          cursor:"pointer",textAlign:"left",fontSize:12,color:"#374151",display:"flex",alignItems:"center",gap:8}}>
                        <span style={{background:isWrong?"#fef2f2":"#f3f4f6",color:isWrong?"#dc2626":"#6b7280",
                          fontSize:10,padding:"2px 6px",borderRadius:4,fontWeight:700,whiteSpace:"nowrap"}}>
                          {isWrong?"❌":"—"} {q.type}
                        </span>
                        <span style={{flex:1,lineHeight:1.4}}>{q.q.length>60?q.q.slice(0,60)+"…":q.q}</span>
                      </button>
                    );
                  })}
                </div>
                {pending.length>4&&<p style={{margin:"8px 0 0",fontSize:11,color:"#9ca3af",textAlign:"center"}}>e altri {pending.length-4}…</p>}
                <button className="action-btn" onClick={()=>openSectionQuiz(card.cat)}
                  style={{marginTop:10,width:"100%",background:cc.acc,color:"white",borderRadius:8,padding:"9px",fontSize:13}}>
                  🧠 Vai ai quiz di {card.cat} →
                </button>
              </div>
            )}
            <div style={{display:"flex",gap:8}}>
              <button className="action-btn" onClick={()=>{setPhase("enunciato");setStep(0);setHint(false);}}
                style={{flex:1,background:"#f3f4f6",color:"#374151",borderRadius:10,padding:"12px",fontSize:14}}>🔄 Rivedi</button>
              <button className="action-btn" onClick={()=>{setNavSection(card.cat);setView("list");}}
                style={{flex:1,background:cc.acc,color:"white",borderRadius:10,padding:"12px",fontSize:14}}>📚 Torna alle schede</button>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

export default function App(){return <EB><AppInner/></EB>;}
