    {sol&&<Lbl x={140} y={62} fill="#7c3aed" fw="700" fs={10}>a=1, b=−4</Lbl>}
    {fin&&<Lbl x={130} y={180} fill="#10b981" fw="700" fs={11}>y=x²−4x+3 ✓</Lbl>}
  </svg>;
};

