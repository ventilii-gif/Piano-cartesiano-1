    <line x1={X(-0.5)} y1={Y(2*(-0.5))} x2={X(5)} y2={Y(2*5)} stroke="#2563eb" strokeWidth="2.3" strokeLinecap="round"/>
    <Lbl x={X(-0.5)+2} y={Y(8.5)} fill="#7c3aed" fw="700" fs={10}>y=x²−2x</Lbl>
    <Lbl x={X(4.6)+2} y={Y(8)+4} fill="#2563eb" fw="700" fs={10}>y=2x</Lbl>
    {roots&&<><Pt x={X(0)} y={Y(0)} fill="#10b981" r={4}/><Pt x={X(4)} y={Y(8)} fill="#10b981" r={4}/></>}
    {fin&&<><Lbl x={X(0)-8} y={Y(0)+14} fill="#10b981" fw="700" fs={10}>(0,0)</Lbl>
      <Lbl x={X(4)+5} y={Y(8)} fill="#10b981" fw="700" fs={10}>(4,8)</Lbl></>}
    {showSys&&<Lbl x={130} y={26} fill="#7c3aed" fw="700" fs={11}>x² = 4x</Lbl>}
    {solve&&<Lbl x={130} y={42} fill="#dc2626" fw="700" fs={11}>x(x−4)=0</Lbl>}
    {fin&&<Lbl x={130} y={58} fill="#10b981" fw="700" fs={11}>x=0, x=4 ✓</Lbl>}
  </svg>;
};

/* 14 · Tangenza — y=2x+k tangente a y=x²+2 → k=1, T(1,3) */
