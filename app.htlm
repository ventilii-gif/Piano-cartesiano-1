    {showT&&<Lbl x={X(2)+4} y={Y(5)+10} fill="#dc2626" fw="700" fs={10}>tang. m=2</Lbl>}
    {showN&&<line x1={X(-2.5)} y1={Y(-(-2.5)/2+3.5)} x2={X(2.5)} y2={Y(-2.5/2+3.5)} stroke="#2563eb" strokeWidth="2.3" strokeLinecap="round" style={{transition:TR}}/>}
    {showN&&<Lbl x={X(2.5)} y={Y(2.25)} fill="#2563eb" fw="700" fs={10}>norm. m=−½</Lbl>}
    {fin&&<RA x={Tx} y={Ty} s={7} r={26.6}/>}
    <Pt x={Tx} y={Ty} fill="#10b981" r={4}/>
    <Lbl x={Tx+5} y={Ty-5} fill="#10b981" fw="700" fs={11}>T(1,3)</Lbl>
    {showM&&<Lbl x={10} y={20} fill="#7c3aed" fw="700" fs={11}>m_t · m_n = −1</Lbl>}
    {fin&&<Lbl x={10} y={36} fill="#10b981" fw="700" fs={10}>y = −x/2 + 7/2 ✓</Lbl>}
  </svg>;
};

const FIGS={1:Fig1,2:Fig2,3:Fig3,4:Fig4,5:Fig5,6:Fig6,7:Fig7,8:Fig8,9:Fig9,10:Fig10,11:Fig11,12:Fig12,13:Fig13,14:Fig14,15:Fig15,16:Fig16};

/* ── DATA ─────────────────────────────────────────────── */
