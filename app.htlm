/* ── Fig17–Fig25: Le Coniche ─────────────────────────── */

/* 17 · Circonferenza centrata nell'origine x²+y²=r² */
const Fig17=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=120,oy=95,u=22;
  const X=x=>ox+x*u, Y=y=>oy-y*u;
  const r=3,rPx=r*u;
  const showP=t>=0,showR=t>=1,showEq=t>=2,showRes=t===3||t===99;
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-4.5} xMax={4.5} yMin={-4} yMax={4} ux={u} uy={u} grid/>
    <circle cx={ox} cy={oy} r={rPx} fill="rgba(8,145,178,0.10)" stroke="#0891b2" strokeWidth="2.2"/>
    {showP&&<><Pt x={X(2)} y={Y(Math.sqrt(5))} label="P(x,y)" dx={5} dy={-5} fill="#dc2626" r={3.5}/>
      <line x1={ox} y1={oy} x2={X(2)} y2={Y(Math.sqrt(5))} stroke={hi(showR,"#0891b2")} strokeWidth={showR?2.2:0} strokeDasharray="5,3" style={{transition:TR}}/></>}
    {showR&&<Lbl x={X(0.8)} y={Y(1.4)} fill="#0891b2" fw="700">r=3</Lbl>}
    {showEq&&<Lbl x={10} y={25} fill="#0891b2" fw="700" fs={13}>x²+y²=9</Lbl>}
    {showRes&&<Lbl x={10} y={40} fill="#10b981" fw="700" fs={11}>Ogni punto a dist. 3 da O ✓</Lbl>}
    <Pt x={ox} y={oy} label="O" dx={-12} dy={10} fill="#374151" r={3}/>
  </svg>;
};

/* 18 · Circonferenza con centro generico C(2,–1), r=2 */
const Fig18=({step:s,phase})=>{
  const t=phase==="done"?99:phase==="steps"?s:-1;
  const ox=80,oy=115,u=24;
