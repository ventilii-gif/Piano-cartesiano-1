    {showAxis&&<line x1={Vx} y1={Y(-1.5)} x2={Vx} y2={Y(5)} stroke="#f97316" strokeWidth="1.4" strokeDasharray="5,3"/>}
    {showFD&&<><line x1={X(-4.5)} y1={Y(-1)} x2={X(4.5)} y2={Y(-1)} stroke="#dc2626" strokeWidth="2" strokeLinecap="round"/>
      <Pt x={Vx} y={Y(1)} fill="#dc2626" r={4}/>
      <Lbl x={Vx+6} y={Y(1)+4} fill="#dc2626" fw="700" fs={11}>F(0,1)</Lbl>
      <Lbl x={X(-4.5)+4} y={Y(-1)+13} fill="#dc2626" fw="700" fs={10}>direttrice  y = −1</Lbl></>}
    {showV&&<Pt x={Vx} y={Vy} fill="#2563eb" r={4}/>}
    {showV&&<Lbl x={Vx+6} y={Vy+15} fill="#2563eb" fw="700" fs={11}>V(0,0)</Lbl>}
    {showAxis&&<Lbl x={Vx+6} y={Y(4)} fill="#ea580c" fw="700" fs={10}>asse  x=0</Lbl>}
    {showCon&&<Lbl x={X(-4)} y={Y(4.5)} fill="#7c3aed" fw="700" fs={11}>a {">"}{" "}0 → ∪</Lbl>}
  </svg>;
};

/* 12 · Studio parabola y = 2x²-4x-6, V(1,-8), radici -1,3, intercetta (0,-6) */
