  const showSec=t===1,showDelta=t>=2,showTan=t>=3,fin=t>=4||t===99;
  const Tx=X(1),Ty=Y(3);
  return <svg viewBox="0 0 240 190" style={{width:"100%",height:"100%"}}>
    <Axes ox={ox} oy={oy} xMin={-3} xMax={3} yMin={-1} yMax={7} ux={ux} uy={uy}/>
    <path d={paraPath(1,0,2,-2.3,2.3,ox,oy,ux,uy)} fill="none" stroke="#7c3aed" strokeWidth="2.6"/>
    <Lbl x={X(-2.3)} y={Y(6.5)} fill="#7c3aed" fw="700" fs={10}>y=x²+2</Lbl>
    {showSec&&!fin&&<><line x1={X(-1.5)} y1={Y(2*(-1.5)+4)} x2={X(2.3)} y2={Y(2*2.3+4)} stroke="#94a3b8" strokeWidth="1.8" strokeDasharray="4,3"/>
      <Lbl x={X(1.7)+4} y={Y(2*1.7+4)} fill="#64748b" fw="700" fs={10}>k=4? Δ{">"}0</Lbl></>}
    {(showTan||fin)&&<line x1={X(-1.3)} y1={Y(2*(-1.3)+1)} x2={X(2.3)} y2={Y(2*2.3+1)} stroke="#dc2626" strokeWidth="2.5" strokeLinecap="round"/>}
    {(showTan||fin)&&<Lbl x={X(2)+4} y={Y(5)+10} fill="#dc2626" fw="700" fs={10}>y=2x+1</Lbl>}
    {fin&&<Pt x={Tx} y={Ty} fill="#10b981" r={4}/>}
    {fin&&<Lbl x={Tx+5} y={Ty-5} fill="#10b981" fw="700" fs={11}>T(1,3)</Lbl>}
    {showDelta&&<Lbl x={10} y={20} fill="#dc2626" fw="700" fs={11}>Δ=0 → k=1</Lbl>}
  </svg>;
};

/* 15 · Parabola per 3 punti — A(0,3), B(1,0), C(-1,8) → y=x²-4x+3 */
